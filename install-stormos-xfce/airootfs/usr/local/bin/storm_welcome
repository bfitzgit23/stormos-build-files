class MaintenanceTab(QWidget):
    """System maintenance actions — mirrors, cache, orphans, keys, etc."""

    def __init__(self, run_cmd: Callable, status_cb: Callable):
        super().__init__()
        self._run_cmd = run_cmd
        self._status = status_cb
        self._build_ui()

    def _build_ui(self):
        scroll = QScrollArea(self)
        scroll.setWidgetResizable(True)
        scroll.setFrameShape(scroll.Shape.NoFrame)
        inner = QWidget()
        layout = QVBoxLayout(inner)
        layout.setSpacing(14)
        scroll.setWidget(inner)

        outer = QVBoxLayout(self)
        outer.setContentsMargins(0, 0, 0, 0)
        outer.addWidget(scroll)

        title = QLabel("System Maintenance")
        title.setStyleSheet("font-size:18px;color:#81A1C1; font-weight:600;")
        layout.addWidget(title)

        # ---- Package cache ----
        g_cache = QGroupBox("Package Cache")
        g_cache.setStyleSheet(GROUP_STYLE)
        gc = QVBoxLayout(g_cache)
        self._add_action(gc,
            "Clear pacman cache (keep last 3 versions)",
            ["sudo", "paccache", "-r"],
            "Remove old cached package versions (requires pacman-contrib).",
            "edit-clear",
        )
        self._add_action(gc,
            "Clear ALL pacman cache",
            ["sudo", "pacman", "-Scc"],
            "Wipe entire /var/cache/pacman/pkg — frees maximum disk space.",
            "edit-delete",
        )
        self._add_action(gc,
            "Remove orphaned packages",
            ["bash", "-c", "sudo pacman -Rns $(pacman -Qdtq) 2>/dev/null || echo 'No orphans.'"],
            "Remove packages that are no longer needed by anything.",
            "user-trash",
        )
        layout.addWidget(g_cache)

        # ---- Mirrors ----
        g_mirrors = QGroupBox("Mirrors & Sync")
        g_mirrors.setStyleSheet(GROUP_STYLE)
        gm = QVBoxLayout(g_mirrors)
        self._add_action(gm,
            "Rank mirrors (reflector — top 20 HTTPS, sorted by speed)",
            ["bash", "-c",
             "sudo reflector --latest 20 --protocol https --sort rate "
             "--save /etc/pacman.d/mirrorlist && echo Done."],
            "Requires: reflector (sudo pacman -S reflector)",
            "network-server",
        )
        self._add_action(gm,
            "Force pacman database sync",
            ["sudo", "pacman", "-Syy"],
            "Force-refresh all package databases.",
            "view-refresh",
        )
        layout.addWidget(g_mirrors)

        # ---- Keys ----
        g_keys = QGroupBox("Keyring")
        g_keys.setStyleSheet(GROUP_STYLE)
        gk = QVBoxLayout(g_keys)
        self._add_action(gk,
            "Refresh keyring",
            ["bash", "-c",
             "sudo pacman -S --needed archlinux-keyring && "
             "sudo pacman-key --refresh-keys"],
            "Fix signature/trust errors.",
            "security-high",
        )
        self._add_action(gk,
            "Reinitialise keyring (drastic fix)",
            ["bash", "-c",
             "sudo rm -rf /etc/pacman.d/gnupg && "
             "sudo pacman-key --init && sudo pacman-key --populate archlinux"],
            "Only needed if the keyring is badly broken.",
            "dialog-warning",
        )
        layout.addWidget(g_keys)

        # ---- Logs ----
        g_logs = QGroupBox("Logs & Journal")
        g_logs.setStyleSheet(GROUP_STYLE)
        gl = QVBoxLayout(g_logs)
        self._add_action(gl,
            "Vacuum journal (keep last 2 weeks)",
            ["sudo", "journalctl", "--vacuum-time=2weeks"],
            "Trim systemd journal to save disk space.",
            "text-x-log",
        )
        self._add_action(gl,
            "View recent journal errors",
            ["journalctl", "-p", "err", "-n", "60", "--no-pager"],
            "Show the last 60 error-level log messages.",
            "dialog-error",
        )
        layout.addWidget(g_logs)

        # ---- Failed services ----
        g_svc = QGroupBox("Services")
        g_svc.setStyleSheet(GROUP_STYLE)
        gs = QVBoxLayout(g_svc)
        self._add_action(gs,
            "List failed systemd services",
            ["systemctl", "--failed"],
            "Show units that failed to start.",
            "dialog-warning",
        )
        self._add_action(gs,
            "Reset failed service state",
            ["sudo", "systemctl", "reset-failed"],
            "Clear the 'failed' state so counts reset.",
            "view-refresh",
        )
        layout.addWidget(g_svc)

        layout.addStretch()

    def _add_action(self, layout, label: str, cmd: List[str],
                    tooltip: str = "", icon: str = ""):
        row = QHBoxLayout()
        btn = QPushButton(label)
        if icon:
            btn.setIcon(QIcon.fromTheme(icon))
        btn.setStyleSheet(BUTTON_STYLE)
        btn.setToolTip(tooltip)
        btn.clicked.connect(
            lambda _, c=cmd, t=label: self._run_cmd(c, t)
        )
        row.addWidget(btn)
        layout.addLayout(row)
        if tooltip:
            lbl = QLabel(tooltip)
            lbl.setStyleSheet("color:#7a8a9a; font-size:11px; margin-left:4px;")
            lbl.setWordWrap(True)
            layout.addWidget(lbl)


