            enable_btn.setObjectName("glassButton")
            enable_btn.clicked.connect(self.enable_autostart)
            disable_btn = QPushButton("Disable autostart")
            disable_btn.setObjectName("glassButton")
            disable_btn.clicked.connect(self.disable_autostart)
            btn_layout.addWidget(enable_btn)
            btn_layout.addWidget(disable_btn)
            btn_layout.addStretch()
            autocard.layout().addLayout(btn_layout)

            layout.addWidget(autocard)
            self.update_autostart_status()

        links_card = self.create_glass_card("🔗 Quick Links")
        links_layout = QHBoxLayout()
        for name, url in [
            ("Arch Wiki", "https://wiki.archlinux.org"),
            ("Arch Forums", "https://bbs.archlinux.org"),
            ("AUR", "https://aur.archlinux.org"),
            ("StormOS GitHub", "https://github.com/stormos"),
        ]:
            btn = QPushButton(name)
            btn.setObjectName("linkButton")
            btn.clicked.connect(lambda checked, u=url: webbrowser.open(u))
            links_layout.addWidget(btn)
        links_layout.addStretch()
        links_card.layout().addLayout(links_layout)
        layout.addWidget(links_card)

        layout.addStretch()
        return tab

