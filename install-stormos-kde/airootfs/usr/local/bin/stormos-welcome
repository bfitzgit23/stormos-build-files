    def search_packages(self):
        query = self.soft_search.text().strip()
        if not query:
            return
        self.package_list.clear()
        self.status_label.setText("Searching...")
        threading.Thread(target=self._do_search, args=(query, self.soft_source.currentText()), daemon=True).start()

    def _do_search(self, query, source):
        packages = []
        if source in ["All", "Pacman"]:
            packages.extend(PacmanBackend().search(query))
        if source in ["All", "AUR"] and shutil.which("yay"):
            packages.extend(YayBackend().search(query))
        QApplication.instance().postEvent(self, SearchResultsEvent(packages))

    def show_installed(self):
        self.package_list.clear()
        self.status_label.setText("Loading installed...")
        threading.Thread(target=self._do_load_installed, daemon=True).start()

    def _do_load_installed(self):
        packages = PacmanBackend().get_installed()
        if shutil.which("yay"):
            packages.extend(YayBackend().get_installed())
        QApplication.instance().postEvent(self, SearchResultsEvent(packages))

    def on_package_selected(self, item, col):
        pkg = item.data(0, Qt.ItemDataRole.UserRole)
        self.selected_package = pkg
        self.details_title.setText(f"{pkg['name']} — {pkg['source']}")
        self.details_text.setText(pkg.get('description', 'No description'))
        self.install_btn.setEnabled(not pkg.get('installed', False))
        self.remove_btn.setEnabled(pkg.get('installed', False))

    def install_package(self):
        if self.selected_package:
            if self.selected_package['source'] == 'pacman':
                run_command(["sudo", "pacman", "-S", "--noconfirm", self.selected_package['name']])
            else:
                run_command(["yay", "-S", "--noconfirm", self.selected_package['name']])

    def remove_package(self):
        if self.selected_package:
            if self.selected_package['source'] == 'pacman':
                run_command(["sudo", "pacman", "-Rns", self.selected_package['name']])
            else:
                run_command(["yay", "-Rns", self.selected_package['name']])

