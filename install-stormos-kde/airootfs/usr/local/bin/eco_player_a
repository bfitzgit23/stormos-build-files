        self.hud_widget = QFrame()
        self.hud_widget.setObjectName("HUD")
        self.hud_widget.setFixedHeight(68)
        
        hud_layout = QHBoxLayout(self.hud_widget)
        hud_layout.setContentsMargins(20, 8, 20, 8)
        hud_layout.setSpacing(16)
        
        # Playback controls
        controls_layout = QHBoxLayout()
        controls_layout.setSpacing(12)
        
        self.prev_btn = QPushButton("⏮")
        self.prev_btn.setFixedSize(40, 40)
        self.prev_btn.setToolTip("Previous Track (←)")
        self.prev_btn.clicked.connect(self.play_previous)
        
        self.play_btn = QPushButton("▶")
        self.play_btn.setFixedSize(52, 52)
        self.play_btn.setStyleSheet(f"""
            QPushButton {{
                color: {FG_GREEN};
                font-size: 20px;
                font-weight: bold;
                background-color: rgba(80, 250, 123, 15);
                border-radius: 26px;
            }}
            QPushButton:hover {{
                background-color: rgba(80, 250, 123, 30);
