class StormWelcome(QMainWindow):
    def __init__(self):
        super().__init__()
        self.is_live = is_live_session()
        self.selected_package = None
        self.init_ui()
        self.apply_styles()
        self.setup_autostart()
        self.animate_window()

    def init_ui(self):
        self.setWindowTitle("🌩️ Storm Welcome")
        self.setMinimumSize(1000, 700)
        screen = QGuiApplication.primaryScreen().geometry()
        self.setGeometry(
            (screen.width() - 1000) // 2,
            (screen.height() - 700) // 2,
            1000, 700
        )

        central = QWidget()
        central.setObjectName("central")
        self.setCentralWidget(central)
        layout = QVBoxLayout(central)
        layout.setContentsMargins(20, 20, 20, 20)
        layout.setSpacing(20)

        layout.addWidget(self.create_header())

        self.tabs = QTabWidget()
        self.tabs.setObjectName("mainTabs")
        self.tabs.addTab(self.create_welcome_tab(), "🚀 Welcome")
        self.tabs.addTab(self.create_system_tab(), "💻 System")
        self.tabs.addTab(self.create_software_tab(), "📦 Software")
        self.tabs.addTab(self.create_maintenance_tab(), "🔧 Maintenance")
        self.tabs.addTab(self.create_drivers_tab(), "🎮 Drivers")
        self.tabs.addTab(self.create_tweaks_tab(), "⚙️ Tweaks")
        self.tabs.addTab(self.create_gaming_tab(), "🎲 Gaming")
        self.tabs.addTab(self.create_settings_tab(), "⚙️ Settings")
        self.tabs.addTab(self.create_help_tab(), "❓ Help")
        layout.addWidget(self.tabs)

        layout.addWidget(self.create_footer())

    # ------------------------------------------------------------------
    # Header, Footer, Glass card helper
    # ------------------------------------------------------------------
    def create_header(self):
        header = QWidget()
        hlayout = QHBoxLayout(header)
        title = QLabel("🌩️ StormOS")
        title.setStyleSheet(f"font-size: 28px; font-weight: bold; color: {STORM_BLUE};")
        subtitle = QLabel("Arch Linux made calm")
        subtitle.setStyleSheet(f"color: {STORM_GRAY}; font-size: 14px; margin-left: 12px;")
        hlayout.addWidget(title)
        hlayout.addWidget(subtitle)
        hlayout.addStretch()
