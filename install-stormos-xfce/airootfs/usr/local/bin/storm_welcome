        layout.addWidget(g_fonts)

        layout.addStretch()


# ============================================================
# GAMING TAB
# ============================================================

class GamingTab(QWidget):
    """Gaming tools: Steam, Lutris, Wine, Proton, MangoHud, etc."""

    def __init__(self, run_cmd: Callable, status_cb: Callable):
        super().__init__()
        self._run_cmd = run_cmd
        self._status = status_cb
        self._build_ui()

    def _build_ui(self):
        scroll = QScrollArea(self)
        scroll.setWidgetResizable(True)
        scroll.setFrameShape(scroll.Shape.NoFrame)
        inner = QWidget()
        layout = QVBoxLayout(inner)
        layout.setSpacing(14)
        scroll.setWidget(inner)

        outer = QVBoxLayout(self)
        outer.setContentsMargins(0, 0, 0, 0)
        outer.addWidget(scroll)

        title = QLabel("Gaming")
        title.setStyleSheet("font-size:18px;color:#81A1C1; font-weight:600;")
        layout.addWidget(title)

        note = QLabel(
            "ℹ  Enable the multilib repository in /etc/pacman.conf before "
            "installing 32-bit (lib32-*) packages."
        )
        note.setStyleSheet("color:#88C0D0; font-size:12px;")
        note.setWordWrap(True)
        layout.addWidget(note)

        # ---- Platforms ----
        g_plat = QGroupBox("Game Platforms")
        g_plat.setStyleSheet(GROUP_STYLE)
        gpl = QVBoxLayout(g_plat)
        for label, cmd in [
            ("Steam",
             ["sudo", "pacman", "-S", "--needed",
              "steam", "steam-native-runtime"]),
            ("Lutris (multi-runner)",
             ["sudo", "pacman", "-S", "--needed", "lutris"]),
            ("Heroic Games Launcher (Epic / GOG / Amazon)",
             ["flatpak", "install", "-y",
              "com.heroicgameslauncher.hgl"]),
            ("Bottles (Wine manager)",
             ["flatpak", "install", "-y",
              "com.usebottles.bottles"]),
            ("GameHub (all-in-one library)",
             ["flatpak", "install", "-y",
              "com.github.tkashkin.gamehub"]),
        ]:
            btn = QPushButton(label)
            btn.setStyleSheet(BUTTON_STYLE)
            btn.clicked.connect(lambda _, c=cmd, t=label: self._run_cmd(c, t))
            gpl.addWidget(btn)
        layout.addWidget(g_plat)

        # ---- Wine / Proton ----
        g_wine = QGroupBox("Wine & Proton")
        g_wine.setStyleSheet(GROUP_STYLE)
        gw = QVBoxLayout(g_wine)
        for label, cmd in [
            ("Wine (staging)",
             ["sudo", "pacman", "-S", "--needed",
              "wine-staging", "wine-mono", "wine-gecko",
              "lib32-gnutls", "lib32-libpulse"]),
            ("Proton-GE (AUR: proton-ge-custom)",
             ["yay", "-S", "proton-ge-custom"]),
            ("ProtonUp-Qt (manage Proton/Wine builds)",
             ["flatpak", "install", "-y",
              "net.davidotek.pupgui2"]),
            ("Winetricks",
             ["sudo", "pacman", "-S", "--needed", "winetricks"]),
        ]:
            btn = QPushButton(label)
            btn.setStyleSheet(BUTTON_STYLE)
            btn.clicked.connect(lambda _, c=cmd, t=label: self._run_cmd(c, t))
            gw.addWidget(btn)
        layout.addWidget(g_wine)

        # ---- Performance ----
        g_perf = QGroupBox("Gaming Performance")
        g_perf.setStyleSheet(GROUP_STYLE)
        gp = QVBoxLayout(g_perf)
        for label, cmd in [
            ("MangoHud (FPS / hardware overlay)",
             ["sudo", "pacman", "-S", "--needed",
              "mangohud", "lib32-mangohud"]),
            ("GOverlay (MangoHud GUI configurator)",
             ["sudo", "pacman", "-S", "--needed", "goverlay"]),
            ("GameMode (CPU/GPU optimiser by Feral)",
             ["sudo", "pacman", "-S", "--needed",
              "gamemode", "lib32-gamemode"]),
            ("Enable GameMode daemon",
             ["sudo", "systemctl", "enable", "--now", "gamemoded"]),
            ("vkBasalt (post-processing effects)",
             ["sudo", "pacman", "-S", "--needed",
              "vkbasalt", "lib32-vkbasalt"]),
        ]:
            btn = QPushButton(label)
            btn.setStyleSheet(BUTTON_STYLE)
            btn.clicked.connect(lambda _, c=cmd, t=label: self._run_cmd(c, t))
            gp.addWidget(btn)
        layout.addWidget(g_perf)

        # ---- Emulation ----
        g_emu = QGroupBox("Emulation")
        g_emu.setStyleSheet(GROUP_STYLE)
        ge = QVBoxLayout(g_emu)
        for label, cmd in [
            ("RetroArch (multi-system emulator)",
             ["sudo", "pacman", "-S", "--needed", "retroarch"]),
            ("Dolphin (GameCube / Wii)",
             ["sudo", "pacman", "-S", "--needed", "dolphin-emu"]),
            ("RPCS3 (PS3 — AUR)",
             ["yay", "-S", "rpcs3-bin"]),
            ("Yuzu / Ryujinx (Switch — AUR/Flatpak)",
             ["flatpak", "install", "-y",
              "org.ryujinx.Ryujinx"]),
            ("PCSX2 (PS2)",
             ["sudo", "pacman", "-S", "--needed", "pcsx2"]),
        ]:
            btn = QPushButton(label)
            btn.setStyleSheet(BUTTON_STYLE)
            btn.clicked.connect(lambda _, c=cmd, t=label: self._run_cmd(c, t))
            ge.addWidget(btn)
        layout.addWidget(g_emu)

        layout.addStretch()


# ============================================================
# MAIN WINDOW
# ============================================================

class WelcomeMenu(QMainWindow):
    def __init__(self):
        super().__init__()
        self._live = is_live_session()
        self.init_ui()
        self.load_settings()

        # If running on an installed system, silently remove autostart entries
        # so this welcome app doesn't nag the user on every boot.
        if not self._live:
            self._maybe_disable_autostart()

    # ----------------------------------------------------------------
    # Autostart removal
    # ----------------------------------------------------------------

    def _maybe_disable_autostart(self):
        """Remove autostart .desktop files if we are on an installed system."""
        removed, errors = disable_autostart()
        # Inform only if something actually changed
        if removed:
            self.set_status(
                "Autostart disabled — app won't launch again after reboot."
            )

    # ----------------------------------------------------------------
    # UI construction
    # ----------------------------------------------------------------

    def _center_window(self):
        screen = QGuiApplication.primaryScreen()
        if screen:
            rect = screen.geometry()
            self.move(
                rect.center().x() - self.width() // 2,
                rect.center().y() - self.height() // 2
            )

    def init_ui(self):
        self.setWindowTitle("StormOS Welcome")
        self.setMinimumSize(1100, 720)
        self.setWindowIcon(QIcon.fromTheme("start-here"))
        self.apply_dark_theme()
        self._center_window()

        central = QWidget()
        self.setCentralWidget(central)
        root = QVBoxLayout(central)
        root.setSpacing(16)

        root.addWidget(self._create_header())
        self.footer = self._create_footer()

        self.tabs = QTabWidget()
        self.tabs.setStyleSheet(TAB_STYLE)
        root.addWidget(self.tabs, 1)

        self._create_welcome_tab()
        self._create_system_tab()
        self._create_software_tab()
        self._create_maintenance_tab()
        self._create_drivers_tab()
        self._create_tweaks_tab()
        self._create_gaming_tab()
        self._create_settings_tab()
        self._create_help_tab()

        root.addWidget(self.footer)

    # ----------------------------------------------------------------
    # Header / Footer
    # ----------------------------------------------------------------

    def _create_header(self):
        box = QWidget()
        layout = QHBoxLayout(box)
        title = QLabel("StormOS")
        title.setFont(QFont("Inter", 26, QFont.Weight.Bold))
        title.setStyleSheet("color: #ECEFF4;")
        subtitle = QLabel("Welcome · Arch Linux")
        subtitle.setStyleSheet("color: #A3BE8C; font-size: 13px;")
        text = QVBoxLayout()
        text.addWidget(title)
        text.addWidget(subtitle)
        layout.addLayout(text)

        if self._live:
            live_badge = QLabel("  LIVE SESSION  ")
            live_badge.setStyleSheet(
                "background:#BF616A; color:#ECEFF4; font-weight:700;"
                " border-radius:6px; padding:4px 10px;"
            )
            layout.addWidget(live_badge)

        layout.addStretch()
        return box

    def _create_footer(self):
        footer_widget = QWidget()
        footer_layout = QHBoxLayout(footer_widget)
        footer_layout.setContentsMargins(10, 4, 10, 4)
        footer_layout.setSpacing(20)
        
        self.status = QLabel("Ready")
        self.status.setStyleSheet("color:#D8DEE9;")
        footer_layout.addWidget(self.status, alignment=Qt.AlignmentFlag.AlignCenter)
        
        env_label = QLabel(f"StormOS · {'Live ISO' if self._live else 'Installed'}")
        env_label.setStyleSheet("color:#88C0D0;")
        footer_layout.addWidget(env_label, alignment=Qt.AlignmentFlag.AlignRight)
        
        footer_widget.setStyleSheet("background:#2E3440;")
        return footer_widget

    def set_status(self, msg: str):
        if hasattr(self, "status") and self.status is not None:
            self.status.setText(msg)
        else:
            try:
                self.statusBar().showMessage(msg, 5000)
            except Exception:
                pass

    # ----------------------------------------------------------------
    # Tabs
    # ----------------------------------------------------------------

    def _create_welcome_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)

        label = QLabel("Welcome to StormOS")
        label.setStyleSheet("font-size: 22px; color: #88C0D0;")
        layout.addWidget(label)

        desc = QLabel(
            "A refined Arch Linux experience focused on performance, "
            "elegance, and control."
        )
        desc.setStyleSheet("color:#D8DEE9;")
        desc.setWordWrap(True)
        layout.addWidget(desc)

        # ---- Calamares installer ----
        installer = QGroupBox("Install StormOS")
        installer.setStyleSheet(GROUP_STYLE)
        il = QVBoxLayout(installer)

        btn_install = QPushButton("Launch Installer (Calamares)")
        btn_install.setIcon(QIcon.fromTheme("system-installer"))
        btn_install.setStyleSheet(BUTTON_STYLE)
        btn_install.clicked.connect(self.launch_calamares)
        il.addWidget(btn_install)

        if not self._live:
            hint = QLabel(
                "⚠  StormOS appears to be running from an installed system. "
                "The installer is intended for use from the live ISO."
            )
            hint.setStyleSheet("color:#EBCB8B;")
            hint.setWordWrap(True)
        else:
            hint = QLabel("Runs the graphical installer to install StormOS to disk.")
            hint.setStyleSheet("color:#AEB7C2;")
            hint.setWordWrap(True)
        il.addWidget(hint)

        # Autostart control (only on installed system)
        if not self._live:
            autostart_box = QGroupBox("Autostart")
            autostart_box.setStyleSheet(GROUP_STYLE)
            al = QVBoxLayout(autostart_box)
            info = QLabel(
                "The Welcome app has been set to not launch automatically "
                "on subsequent logins. You can re-enable it below."
            )
            info.setStyleSheet("color:#D8DEE9;")
            info.setWordWrap(True)
            al.addWidget(info)
            btn_re = QPushButton("Re-enable autostart")
            btn_re.setStyleSheet(BUTTON_STYLE)
            btn_re.clicked.connect(self._reenable_autostart)
            al.addWidget(btn_re)
            layout.addWidget(autostart_box)

        layout.addWidget(installer)

        quick = QGroupBox("Quick Links")
        quick.setStyleSheet(GROUP_STYLE)
        ql = QVBoxLayout(quick)
        for label_text, url, icon in [
            ("Arch Wiki", "https://wiki.archlinux.org", "help-contents"),
            ("Arch Forums", "https://bbs.archlinux.org", "internet-services"),
            ("AUR", "https://aur.archlinux.org", "system-software-install"),
            ("StormOS GitHub", "https://github.com", "system-file-manager"),
        ]:
            btn = QPushButton(label_text)
            btn.setIcon(QIcon.fromTheme(icon))
            btn.setStyleSheet(BUTTON_STYLE)
            btn.clicked.connect(lambda _, u=url: webbrowser.open(u))
            ql.addWidget(btn)

        layout.addWidget(quick)
        layout.addStretch()
        self.tabs.addTab(tab, "Welcome")

    def _reenable_autostart(self):
        desktop_content = (
            "[Desktop Entry]\n"
            "Type=Application\n"
            "Name=StormOS Welcome\n"
            "Exec=stormos-welcome\n"
            "Icon=start-here\n"
            "Comment=StormOS Welcome Screen\n"
            "X-GNOME-Autostart-enabled=true\n"
        )
        target = Path.home() / ".config/autostart/stormos-welcome.desktop"
        try:
            target.parent.mkdir(parents=True, exist_ok=True)
            target.write_text(desktop_content)
            QMessageBox.information(
                self, "Autostart enabled",
                f"Autostart entry written to:\n{target}\n\n"
                "The welcome app will open on next login."
            )
            self.set_status("Autostart re-enabled.")
        except Exception as e:
            QMessageBox.warning(self, "Error", str(e))

    def _create_system_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)
        group = QGroupBox("System Actions")
        group.setStyleSheet(GROUP_STYLE)
        g = QVBoxLayout(group)

        for text, cmd, icon in [
            ("Update System (pacman -Syu)",
             ["sudo", "pacman", "-Syu"],
             "system-software-update"),
            ("Update System + AUR (yay -Syu)",
             ["yay", "-Syu"],
             "system-software-update"),
            ("Reboot",
             ["sudo", "reboot"],
             "system-reboot"),
            ("Shutdown",
             ["sudo", "shutdown", "-h", "now"],
             "system-shutdown"),
        ]:
            btn = QPushButton(text)
            btn.setIcon(QIcon.fromTheme(icon))
            btn.setStyleSheet(BUTTON_STYLE)
            btn.clicked.connect(
                lambda _, c=cmd, t=text: self.run_cmd(c, t)
            )
            g.addWidget(btn)

        note = QLabel(
            "Note: commands open in xfce4-terminal (must be installed)."
        )
        note.setStyleSheet("color:#D8DEE9; font-size: 12px;")
        g.addWidget(note)

        layout.addWidget(group)
        layout.addStretch()
        self.tabs.addTab(tab, "System")

    def _create_software_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)
        self.software_center = SoftwareCenter(status_cb=self.set_status)
        layout.addWidget(self.software_center, 1)
        self.tabs.addTab(tab, "Software")

    def _create_maintenance_tab(self):
        tab = MaintenanceTab(
            run_cmd=self.run_cmd,
            status_cb=self.set_status,
        )
        self.tabs.addTab(tab, "Maintenance")

    def _create_drivers_tab(self):
        tab = DriversTab(
            run_cmd=self.run_cmd,
            status_cb=self.set_status,
        )
        self.tabs.addTab(tab, "Drivers")

    def _create_tweaks_tab(self):
        tab = TweaksTab(
            run_cmd=self.run_cmd,
            status_cb=self.set_status,
        )
        self.tabs.addTab(tab, "Tweaks")

    def _create_gaming_tab(self):
        tab = GamingTab(
            run_cmd=self.run_cmd,
            status_cb=self.set_status,
        )
        self.tabs.addTab(tab, "Gaming")

    def _create_settings_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)

        appearance = QGroupBox("Appearance")
        appearance.setStyleSheet(GROUP_STYLE)
        form = QFormLayout(appearance)

        self.theme = QComboBox()
        self.theme.addItems(["Dark", "Light"])
        self.theme.currentTextChanged.connect(self.change_theme)

        self.font_slider = QSlider(Qt.Orientation.Horizontal)
        self.font_slider.setRange(10, 18)
        self.font_slider.valueChanged.connect(self.change_font)

        form.addRow("Theme", self.theme)
        form.addRow("Font Size", self.font_slider)
        layout.addWidget(appearance)

        desktop = QGroupBox("Desktop Tools")
        desktop.setStyleSheet(GROUP_STYLE)
        d = QVBoxLayout(desktop)
        for text, cmd, icon in [
            ("Display Settings (arandr)",
             ["arandr"], "video-display"),
            ("Wallpaper (nitrogen)",
             ["nitrogen"], "preferences-desktop-wallpaper"),
            ("Network (nm-connection-editor)",
             ["nm-connection-editor"], "network-wireless"),
            ("Compositor (picom)",
             ["picom", "--experimental-backends"], "preferences-system"),
        ]:
            btn = QPushButton(text)
            btn.setIcon(QIcon.fromTheme(icon))
            btn.setStyleSheet(BUTTON_STYLE)
            btn.clicked.connect(
                lambda _, c=cmd, t=text: self.run_cmd(c, t, hold=False)
            )
            d.addWidget(btn)

        layout.addWidget(desktop)
        layout.addStretch()
        self.tabs.addTab(tab, "Settings")

    def _create_help_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)
        group = QGroupBox("Help & Resources")
        group.setStyleSheet(GROUP_STYLE)
        g = QVBoxLayout(group)

        for text, action, icon in [
            ("Arch Wiki",
             lambda: webbrowser.open("https://wiki.archlinux.org"),
             "help-contents"),
            ("Arch Linux Forums",
             lambda: webbrowser.open("https://bbs.archlinux.org"),
             "internet-services"),
            ("Report an issue",
             lambda: QMessageBox.information(
                 self, "Issues",
                 "Point this button to your StormOS issue tracker URL."
             ),
             "dialog-information"),
            ("About StormOS",
             lambda: QMessageBox.about(
                 self, "About StormOS",
                 "StormOS — an Arch Linux distribution.\n\n"
                 "Built with PyQt6.\n"
             ),
             "help-about"),
        ]:
            btn = QPushButton(text)
            btn.setIcon(QIcon.fromTheme(icon))
            btn.setStyleSheet(BUTTON_STYLE)
            btn.clicked.connect(action)
            g.addWidget(btn)

        layout.addWidget(group)
        layout.addStretch()
        self.tabs.addTab(tab, "Help")

    # ----------------------------------------------------------------
    # Calamares launcher — DARK MODE FIXED
    # ----------------------------------------------------------------

    def launch_calamares(self):
        exe = shutil.which("calamares")
        if not exe:
            QMessageBox.warning(
                self, "Installer not found",
                "Calamares was not found on this system.\n\n"
                "On Arch-based systems you may need to install it, "
                "or include it in the ISO build.",
            )
            return

        # Build environment that forces Calamares into dark / Fusion mode.
        # This works for both Qt5 and Qt6 builds of Calamares.
        dark_env = {
            **os.environ,
            # Force Qt Fusion style (cross-platform, respects palette)
            "QT_STYLE_OVERRIDE": "Fusion",
            # Qt colour scheme hint (Qt >= 6.5 / some Qt5 builds honour this)
            "QT_QPA_PLATFORMTHEME": "gnome",   # fallback; set after
            "XCURSOR_THEME": os.environ.get("XCURSOR_THEME", "Adwaita"),
            # GTK theme (if Calamares uses GTK dialogs)
            "GTK_THEME": "Adwaita:dark",
            # Force dark preference for Qt Quick / KDE apps
            "QT_QUICK_CONTROLS_STYLE": "Material",
            "QT_QUICK_CONTROLS_MATERIAL_THEME": "Dark",
        }
        # Remove variables known to force light themes
        for var in ("QT_STYLE", "QT_PLATFORM_PLUGIN"):
            dark_env.pop(var, None)

        try:
            if hasattr(os, "geteuid") and os.geteuid() == 0:
                subprocess.Popen([exe], env=dark_env)
                self.set_status("Launching Calamares (dark)…")
                return

            pkexec = shutil.which("pkexec")
            if pkexec:
                # pkexec strips env; pass variables explicitly via env(1)
                env_args = [f"{k}={v}" for k, v in dark_env.items()]
                subprocess.Popen([pkexec, "env"] + env_args + [exe])
                self.set_status("Launching Calamares via pkexec (dark)…")
                return

            # Last resort: sudo inside xfce4-terminal with env vars
            env_str = " ".join(
                f'{k}="{v}"' for k, v in dark_env.items()
                if k.startswith(("QT_", "GTK_", "XCURSOR_"))
            )
            self.run_cmd(
                ["bash", "-c", f"sudo -E env {env_str} {exe}"],
                title="Calamares Installer",
                hold=False,
            )
        except Exception as e:
            QMessageBox.warning(self, "Failed to launch installer", str(e))

    # ----------------------------------------------------------------
    # Command runner
    # ----------------------------------------------------------------

    def run_cmd(self, cmd: List[str], title: str = "StormOS",
                hold: bool = True):
        try:
            run_in_terminal(cmd, title=title, hold=hold)
            self.set_status("Command started in terminal")
        except Exception as e:
            QMessageBox.warning(self, "Terminal error", str(e))

    # ----------------------------------------------------------------
    # Theme / font
    # ----------------------------------------------------------------

    def change_theme(self, theme: str):
        if theme == "Dark":
            self.apply_dark_theme()
        else:
            self.apply_light_theme()

    def change_font(self, size: int):
        font = self.font()
        font.setPointSize(size)
        self.setFont(font)

    def load_settings(self):
        self.theme.setCurrentText("Dark")
        self.font_slider.setValue(12)

    def apply_dark_theme(self):
        self.setStyleSheet("QWidget { background:#2E3440; color:#D8DEE9; }")

    def apply_light_theme(self):
        self.setStyleSheet("QWidget { background:#F4F6F8; color:#1E1E1E; }")


# ============================================================
# ENTRY POINT
# ============================================================

def main():
    app = QApplication(sys.argv)
    app.setStyle("Fusion")
    win = WelcomeMenu()
    win.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
