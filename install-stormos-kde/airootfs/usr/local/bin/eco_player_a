        layout.addStretch()
        layout.addLayout(btn_layout)
        
        dialog.exec()
    
    # ===== WINDOW DECORATION HANDLING =====
    def get_resize_edge(self, global_pos):
        """Determine which edge of the window is being hovered for resizing"""
        rect = self.geometry()
        x, y = global_pos.x(), global_pos.y()
        margin = self.min_margin
        
        edges = {
            'top': y < rect.top() + margin and rect.left() + margin < x < rect.right() - margin,
            'bottom': y > rect.bottom() - margin and rect.left() + margin < x < rect.right() - margin,
            'left': x < rect.left() + margin and rect.top() + margin < y < rect.bottom() - margin,
            'right': x > rect.right() - margin and rect.top() + margin < y < rect.bottom() - margin,
            'top_left': x <= rect.left() + margin and y <= rect.top() + margin,
            'top_right': x >= rect.right() - margin and y <= rect.top() + margin,
            'bottom_left': x <= rect.left() + margin and y >= rect.bottom() - margin,
            'bottom_right': x >= rect.right() - margin and y >= rect.bottom() - margin,
        }
        
        for edge, condition in edges.items():
            if condition:
                return edge
        return None
    
    def get_cursor_shape(self, edge):
        """Get appropriate cursor shape for window edge"""
        cursors = {
            'top': Qt.CursorShape.SizeVerCursor,
            'bottom': Qt.CursorShape.SizeVerCursor,
            'left': Qt.CursorShape.SizeHorCursor,
            'right': Qt.CursorShape.SizeHorCursor,
            'top_left': Qt.CursorShape.SizeFDiagCursor,
            'top_right': Qt.CursorShape.SizeBDiagCursor,
            'bottom_left': Qt.CursorShape.SizeBDiagCursor,
            'bottom_right': Qt.CursorShape.SizeFDiagCursor,
        }
        return cursors.get(edge, Qt.CursorShape.ArrowCursor)
    
    def mousePressEvent(self, event):
        if event.button() == Qt.MouseButton.LeftButton:
            global_pos = event.globalPosition().toPoint()
            self.resize_edge = self.get_resize_edge(global_pos)
            
            if self.resize_edge:
                self.resizing = True
                self.mouse_pos = global_pos
                event.accept()
                return
            
            # Only allow dragging from header when not maximized/fullscreen
            if (not self.is_fullscreen and not self.isMaximized() and 
                event.position().y() < 42):
                self.mouse_pos = global_pos
                event.accept()
                return
        
        super().mousePressEvent(event)
    
    def mouseMoveEvent(self, event):
        global_pos = event.globalPosition().toPoint()
        
        if self.resizing and self.mouse_pos:
            self.handle_resize(global_pos)
            event.accept()
            return
        
        if self.mouse_pos and not self.is_fullscreen and not self.isMaximized():
            delta = global_pos - self.mouse_pos
            self.move(self.x() + delta.x(), self.y() + delta.y())
            self.mouse_pos = global_pos
            event.accept()
            return
        
        # Update cursor for resizing edges
        edge = self.get_resize_edge(global_pos)
        if edge and not self.isMaximized() and not self.is_fullscreen:
            self.setCursor(self.get_cursor_shape(edge))
        else:
            self.setCursor(Qt.CursorShape.ArrowCursor)
            # Restart cursor hide timer in fullscreen
            if self.is_fullscreen:
                self.cursor_timer.start(3000)
                self.setCursor(Qt.CursorShape.ArrowCursor)
        
        super().mouseMoveEvent(event)
    
    def handle_resize(self, global_pos):
        """Handle window resizing based on edge being dragged"""
        delta = global_pos - self.mouse_pos
        self.mouse_pos = global_pos
        geo = self.geometry()
        min_size = self.minimum_size
        
        new_geo = QRect(geo)
        
        if self.resize_edge == 'top':
            new_geo.setTop(new_geo.top() + delta.y())
        elif self.resize_edge == 'bottom':
            new_geo.setBottom(new_geo.bottom() + delta.y())
        elif self.resize_edge == 'left':
            new_geo.setLeft(new_geo.left() + delta.x())
        elif self.resize_edge == 'right':
            new_geo.setRight(new_geo.right() + delta.x())
        elif self.resize_edge == 'top_left':
            new_geo.setTopLeft(new_geo.topLeft() + delta)
        elif self.resize_edge == 'top_right':
            new_geo.setTopRight(new_geo.topRight() + delta)
        elif self.resize_edge == 'bottom_left':
            new_geo.setBottomLeft(new_geo.bottomLeft() + delta)
        elif self.resize_edge == 'bottom_right':
            new_geo.setBottomRight(new_geo.bottomRight() + delta)
        
        # Enforce minimum size
        if new_geo.width() >= min_size.width() and new_geo.height() >= min_size.height():
            self.setGeometry(new_geo)
    
    def mouseReleaseEvent(self, event):
        self.resizing = False
        self.resize_edge = None
        self.mouse_pos = None
        super().mouseReleaseEvent(event)
    
    def mouseDoubleClickEvent(self, event):
        """Double-click header to maximize/restore"""
        if event.position().y() < 42 and not self.is_fullscreen:
            self.toggle_maximize_restore()
        event.accept()
    
    def resizeEvent(self, event):
        """Handle resize events for child widgets"""
        super().resizeEvent(event)
        if hasattr(self, 'buffering_progress') and self.buffering_progress:
            self.buffering_progress.resize(self.video_widget.width(), 4)
    
    def eventFilter(self, obj, event):
        """Filter events for video widget"""
        if obj == self.video_widget:
            if event.type() == QEvent.Type.MouseButtonDblClick:
                self.toggle_fullscreen()
                return True
            elif event.type() == QEvent.Type.MouseMove:
                if self.is_fullscreen:
                    self.setCursor(Qt.CursorShape.ArrowCursor)
                    self.cursor_timer.start(3000)
                return False
        
        return super().eventFilter(obj, event)
    
    def show_notification(self, message, duration=2000):
        """Show a subtle notification tooltip"""
        QToolTip.showText(
            self.mapToGlobal(self.rect().center()),
            message,
            self,
            QRect(),
            duration
        )
    
    def closeEvent(self, event):
        """Clean up media resources on close"""
        self.player.stop()
        self.player.setSource(QUrl())
        event.accept()


def setup_stormos_environment():
    """Configure environment for optimal StormOS integration"""
    # Set application metadata
    QApplication.setApplicationName("StormPlayer")
    QApplication.setApplicationVersion("1.0.0")
    QApplication.setOrganizationName("StormOS")
    QApplication.setDesktopFileName("stormplayer")
    
    # Set fallback fonts that are common on Arch/StormOS
    font_families = [
        "JetBrains Mono", 
        "Fira Code", 
        "Mononoki", 
        "Hack", 
        "DejaVu Sans Mono",
        "monospace"
    ]
    
    for family in font_families:
        font = QFont(family)
        if font.exactMatch():
            QApplication.setFont(font)
            break
    else:
        # Fallback to system default monospace
        font = QFont("monospace")
        font.setStyleHint(QFont.StyleHint.Monospace)
        QApplication.setFont(font)


def main():
    """Main entry point for StormPlayer"""
    app = QApplication(sys.argv)
    app.setQuitOnLastWindowClosed(True)
    
    # Setup StormOS environment
    setup_stormos_environment()
    
    # Create player window
    player = StormPlayer()
    player.show()
    
    # Handle command-line arguments (files to open)
    if len(sys.argv) > 1:
        media_files = []
        for arg in sys.argv[1:]:
            if os.path.isfile(arg) and player.is_media_file(arg):
                media_files.append(os.path.abspath(arg))
        
        if media_files:
            player.add_to_playlist(media_files, clear_first=True)
            player.play_item(0)
    
    # Start event loop
    sys.exit(app.exec())


if __name__ == "__main__":
    # Ensure we're running on Linux/StormOS
    if sys.platform != "linux":
        print("⚠️  StormPlayer is optimized for StormOS (Linux). Some features may not work correctly on other platforms.")
    
    # Check for required GStreamer plugins (common on Arch)
    try:
        subprocess.run(["gst-inspect-1.0", "playback"], 
                      capture_output=True, timeout=2)
    except (subprocess.SubprocessError, FileNotFoundError):
        print("⚠️  GStreamer plugins may not be installed. For best results on StormOS, install:")
        print("   sudo pacman -S gst-plugins-base gst-plugins-good gst-plugins-bad gst-plugins-ugly")
    
    main()