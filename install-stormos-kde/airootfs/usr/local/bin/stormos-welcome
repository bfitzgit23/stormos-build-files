        for name, url in [
            ("Arch Wiki", "https://wiki.archlinux.org"),
            ("Arch Forums", "https://bbs.archlinux.org"),
        ]:
            btn = QPushButton(name)
            btn.setObjectName("linkButton")
            btn.clicked.connect(lambda checked, u=url: webbrowser.open(u))
            help_card.layout().addWidget(btn)

        about_btn = QPushButton("About StormOS")
        about_btn.setObjectName("linkButton")
        about_btn.clicked.connect(lambda: QMessageBox.about(self, "About StormOS",
            "StormOS Welcome v2.0\n\nModern welcome and software center for StormOS\n\nBuilt with PyQt6\nUses dolphin for commands"))
        help_card.layout().addWidget(about_btn)

        layout.addWidget(help_card)
        layout.addStretch()
        return tab

    def create_glass_card(self, title: str) -> QGroupBox:
        card = QGroupBox(title)
        card.setStyleSheet(f"""
            QGroupBox {{
                background-color: {STORM_GLASS_DARK};
                border: 1px solid rgba(100, 255, 218, 0.2);
                border-radius: 16px;
                margin-top: 12px;
                padding-top: 12px;
                font-weight: bold;
                color: {STORM_BLUE};
            }}
            QGroupBox::title {{
                subcontrol-origin: margin;
                left: 16px;
                padding: 0 8px;
            }}
        """)
        layout = QVBoxLayout(card)
        layout.setSpacing(12)
        return card

