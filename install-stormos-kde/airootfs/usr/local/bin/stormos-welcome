    def animate_window(self):
        self.setWindowOpacity(0)
        anim = QPropertyAnimation(self, b"windowOpacity")
        anim.setDuration(400)
        anim.setStartValue(0)
        anim.setEndValue(1)
        anim.setEasingCurve(QEasingCurve.Type.OutCubic)
        anim.start()

    def setup_autostart(self):
        if not self.is_live and not AUTOSTART_DISABLED_MARKER.exists():
            QTimer.singleShot(1000, self.disable_autostart_once)

    def disable_autostart_once(self):
        self.disable_autostart()
        AUTOSTART_DISABLED_MARKER.touch()
        self.update_autostart_status()

    def enable_autostart(self):
        AUTOSTART_FILE.parent.mkdir(parents=True, exist_ok=True)
        AUTOSTART_FILE.write_text("""[Desktop Entry]
Type=Application
Name=StormOS Welcome
Exec=stormos-welcome
Icon=stormos-welcome
Comment=StormOS Welcome Screen
X-GNOME-Autostart-enabled=true
Terminal=false
Categories=System;
""")
        if AUTOSTART_DISABLED_MARKER.exists():
            AUTOSTART_DISABLED_MARKER.unlink()
        self.update_autostart_status()
        self.status_label.setText("Autostart enabled")

    def disable_autostart(self):
        if AUTOSTART_FILE.exists():
            AUTOSTART_FILE.unlink()
        AUTOSTART_DISABLED_MARKER.touch()
        self.update_autostart_status()
        self.status_label.setText("Autostart disabled")

    def update_autostart_status(self):
        if not hasattr(self, 'autostatus'):
            return
        if AUTOSTART_FILE.exists() and not AUTOSTART_DISABLED_MARKER.exists():
            self.autostatus.setText("✓ Autostart is currently ENABLED")
            self.autostatus.setStyleSheet(f"color: {STORM_TEAL}; margin-bottom: 8px;")
        else:
            self.autostatus.setText("✗ Autostart is currently DISABLED")
            self.autostatus.setStyleSheet(f"color: {STORM_CORAL}; margin-bottom: 8px;")

    def run_system_cmd(self, cmd: List[str], title: str):
        run_command(cmd, title)
        self.status_label.setText(f"Running: {title}")

    def launch_calamares(self):
        if not shutil.which("calamares"):
            QMessageBox.warning(self, "Installer not found",
                "Calamares is not installed. This feature is only available in the live ISO.")
            return
        run_command(["calamares"], "Calamares Installer", hold=False)
        self.status_label.setText("Launching Calamares...")

    def search_packages(self):
        query = self.search_input.text().strip()
        source = self.source_combo.currentText()
        if not query:
            return
        self.package_list.clear()
        self.status_label.setText("Searching...")
        threading.Thread(target=self._do_search, args=(query, source), daemon=True).start()

    def _do_search(self, query: str, source: str):
        packages = []
        if source in ["All", "Pacman"]:
            packages.extend(PacmanBackend().search(query))
        if source in ["All", "AUR"] and shutil.which("yay"):
            packages.extend(YayBackend().search(query))
        QApplication.instance().postEvent(self, SearchResultsEvent(packages))

    def show_installed(self):
        self.package_list.clear()
        self.status_label.setText("Loading installed...")
        threading.Thread(target=self._do_load_installed, daemon=True).start()

    def _do_load_installed(self):
        packages = []
        packages.extend(PacmanBackend().get_installed())
        if shutil.which("yay"):
            packages.extend(YayBackend().get_installed())
        QApplication.instance().postEvent(self, SearchResultsEvent(packages))

    def on_package_selected(self, item: QTreeWidgetItem, col: int):
        self.selected_package = {
            'name': item.text(0),
            'version': item.text(1),
            'source': item.text(2),
            'installed': item.data(0, Qt.ItemDataRole.UserRole)
        }
        self.details_title.setText(f"{self.selected_package['name']} — {self.selected_package['source']}")
        self.details_text.setText("Select Install or Remove to manage this package.")
        self.install_btn.setEnabled(not self.selected_package['installed'])
        self.remove_btn.setEnabled(self.selected_package['installed'])

    def install_package(self):
        if not self.selected_package:
            return
        pkg = self.selected_package['name']
        if self.selected_package['source'] == 'pacman':
            run_command(["sudo", "pacman", "-S", "--noconfirm", pkg])
        else:
            run_command(["yay", "-S", "--noconfirm", pkg])
        self.status_label.setText(f"Installing {pkg}...")

    def remove_package(self):
        if not self.selected_package:
            return
        pkg = self.selected_package['name']
        if self.selected_package['source'] == 'pacman':
            run_command(["sudo", "pacman", "-Rns", pkg])
        else:
            run_command(["yay", "-Rns", pkg])
        self.status_label.setText(f"Removing {pkg}...")

    def change_theme(self, theme: str):
        if "Dark" in theme:
            self.apply_styles()
        else:
            self.setStyleSheet("QMainWindow { background-color: #f0f0f0; } QLabel { color: #000; }")

    def customEvent(self, event):
        if isinstance(event, SearchResultsEvent):
            self._display_results(event.packages)

    def _display_results(self, packages: List[Dict]):
        self.package_list.clear()
        for pkg in packages:
            item = QTreeWidgetItem([pkg['name'], pkg['version'], pkg['source']])
            item.setData(0, Qt.ItemDataRole.UserRole, pkg.get('installed', False))
            if pkg.get('installed', False):
                item.setForeground(0, QColor(STORM_TEAL))
            self.package_list.addTopLevelItem(item)
        self.backend_status.setText(f"Pacman: ✓ | AUR: {'✓' if shutil.which('yay') else '✗'}")
        self.status_label.setText(f"Found {len(packages)} packages")


class SearchResultsEvent:
    def __init__(self, packages):
        self.packages = packages


def is_live_session() -> bool:
    for marker in LIVE_MARKERS:
        if Path(marker).exists():
            return True
    return False


def main():
    app = QApplication(sys.argv)
    app.setApplicationName("StormOS Welcome")
    app.setStyle("Fusion")
    palette = QPalette()
    palette.setColor(QPalette.ColorRole.Window, QColor(STORM_NAVY))
    palette.setColor(QPalette.ColorRole.WindowText, QColor(STORM_LIGHT))
    palette.setColor(QPalette.ColorRole.Base, QColor(STORM_DARK))
    palette.setColor(QPalette.ColorRole.Text, QColor(STORM_LIGHT))
    app.setPalette(palette)

    window = StormWelcome()
    window.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
