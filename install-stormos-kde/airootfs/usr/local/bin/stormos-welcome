# ============================================================
# TERMINAL HANDLING - PRIORITIZE dolphin
# ============================================================

def find_terminal() -> Optional[str]:
    """Find available terminal emulator, preferring dolphin."""
    # Priority order: dolphin first, then xfce4-terminal, xterm, etc.
    terminals = ["dolphin", "xfce4-terminal", "xterm", "konsole"]
    for term in terminals:
        if shutil.which(term):
            return shutil.which(term)
    return None


def run_command(cmd: List[str], title: str = "StormOS", hold: bool = True):
    """Run command using dolphin (or fallback) with proper PTY handling."""
    # Use pkexec for sudo commands (graphical password dialog)
    if cmd[0] == "sudo" and shutil.which("pkexec"):
        try:
            subprocess.Popen(["pkexec"] + cmd[1:], start_new_session=True,
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except Exception:
            pass

    term = find_terminal()
    if not term:
        QMessageBox.warning(None, "Terminal Error",
                           "No terminal found.\nPlease install dolphin or xfce4-terminal.")
        return False

    # Build command string with proper escaping
    cmd_str = " ".join(f'"{arg}"' if " " in arg or "'" in arg else arg for arg in cmd)

    # Create a shell command that keeps the terminal open if hold=True
    if hold:
        wrapper = f'bash -c "{cmd_str}; echo; echo \'Press Enter to close...\'; read"'
    else:
        wrapper = f'bash -c "{cmd_str}"'

    term_name = os.path.basename(term)

    # dolphin specific arguments
    if term_name == "dolphin":
        # Use -- to separate options from the command
        args = [term, "--title", title, "--", "bash", "-c", wrapper]
    elif term_name == "xfce4-terminal":
        args = [term, "--disable-server", "--title", title, "--command", wrapper]
    elif term_name == "xterm":
        args = [term, "-title", title, "-e", wrapper]
    else:
        # Generic fallback
        args = [term, "-e", wrapper]

    try:
        subprocess.Popen(args, start_new_session=True,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True
    except Exception as e:
        QMessageBox.warning(None, "Terminal Error", str(e))
        return False


def run_capture(cmd: List[str]) -> tuple:
    """Run command and capture output (for package search)."""
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        return result.returncode, result.stdout, result.stderr
    except Exception:
        return 1, "", ""


# ============================================================
# PACKAGE BACKENDS (unchanged)
# ============================================================

class PackageBackend:
    def search(self, query: str) -> List[Dict]:
        raise NotImplementedError
    def get_installed(self) -> List[Dict]:
        raise NotImplementedError
    def install(self, pkg: str):
        run_command(["sudo", "pacman", "-S", "--noconfirm", pkg])
    def remove(self, pkg: str):
        run_command(["sudo", "pacman", "-Rns", pkg])


class PacmanBackend(PackageBackend):
    def search(self, query: str) -> List[Dict]:
        rc, out, _ = run_capture(["pacman", "-Ss", query])
        if rc != 0: return []
        packages = []
        lines = out.split('\n')
        i = 0
        while i < len(lines):
            line = lines[i].strip()
            if line and not line.startswith(' '):
                parts = line.split()
                if len(parts) >= 3:
                    name = parts[1] if '/' in parts[0] else parts[0].split('/')[-1]
                    version = parts[2]
                    desc = lines[i+1].strip() if i+1 < len(lines) else ''
                    packages.append({
                        'name': name, 'version': version, 'description': desc,
                        'source': 'pacman', 'installed': 'installed' in line.lower()
                    })
            i += 1
        return packages

    def get_installed(self) -> List[Dict]:
        rc, out, _ = run_capture(["pacman", "-Q"])
        if rc != 0: return []
        packages = []
        for line in out.split('\n'):
            if line.strip():
                parts = line.split()
                if len(parts) >= 2:
                    packages.append({
                        'name': parts[0], 'version': parts[1],
                        'description': '', 'source': 'pacman', 'installed': True
                    })
        return packages


class YayBackend(PackageBackend):
    def search(self, query: str) -> List[Dict]:
        if not shutil.which("yay"): return []
        rc, out, _ = run_capture(["yay", "-Ss", query])
        if rc != 0: return []
        packages = []
        for line in out.split('\n'):
            if line.startswith('aur/'):
                parts = line.split()
                name = parts[0].split('/')[1]
                version = parts[1] if len(parts) > 1 else ''
                packages.append({
                    'name': name, 'version': version, 'description': '',
                    'source': 'aur', 'installed': 'Installed' in line
                })
        return packages

    def get_installed(self) -> List[Dict]:
        rc, out, _ = run_capture(["pacman", "-Qm"])
        if rc != 0: return []
        packages = []
        for line in out.split('\n'):
            if line.strip():
                parts = line.split()
                if len(parts) >= 2:
                    packages.append({
                        'name': parts[0], 'version': parts[1],
                        'description': '', 'source': 'aur', 'installed': True
                    })
        return packages

    def install(self, pkg: str):
        run_command(["yay", "-S", "--noconfirm", pkg])
    def remove(self, pkg: str):
        run_command(["yay", "-Rns", pkg])


