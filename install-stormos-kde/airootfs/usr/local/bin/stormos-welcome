#!/usr/bin/env python3
import sys
from PyQt6.QtWidgets import QApplication, QMainWindow, QLabel, QWidget, QVBoxLayout
from PyQt6.QtCore import Qt

class SafeHub(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("StormOS Hub (Safe Mode)")
        self.setGeometry(100, 100, 1000, 800)  # fixed position, no animation
        central = QWidget()
        layout = QVBoxLayout(central)
        label = QLabel("If you see this, the safe window works.\nNow we can add cards.")
        layout.addWidget(label)
        self.setCentralWidget(central)
        self.show()
        self.raise_()
        self.activateWindow()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    win = SafeHub()
    sys.exit(app.exec())
