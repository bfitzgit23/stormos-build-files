             ["sudo", "mkinitcpio", "-P"]),
        ]:
            btn = QPushButton(label)
            btn.setStyleSheet(BUTTON_STYLE)
            btn.clicked.connect(lambda _, c=cmd, t=label: self._run_cmd(c, t))
            gb.addWidget(btn)
        layout.addWidget(g_boot)

        # ---- Performance ----
        g_perf = QGroupBox("Performance & Power")
        g_perf.setStyleSheet(GROUP_STYLE)
        gp = QVBoxLayout(g_perf)
        for label, cmd in [
            ("Install TLP (laptop power management)",
             ["sudo", "pacman", "-S", "--needed", "tlp", "tlp-rdw"]),
