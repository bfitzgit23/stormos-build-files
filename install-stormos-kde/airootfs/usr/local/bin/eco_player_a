class StormPlayer(QMainWindow):
    """Dracula-themed media player for StormOS"""
    
    playlistChanged = pyqtSignal()
    playbackStateChanged = pyqtSignal(QMediaPlayer.PlaybackState)
    
    def __init__(self):
        super().__init__()
        self.setWindowTitle("StormPlayer")
        self.setWindowIcon(QIcon.fromTheme("video-player", QIcon.fromTheme("multimedia-video-player")))
        
        # Window setup
        self.setWindowFlags(
            Qt.WindowType.FramelessWindowHint |
            Qt.WindowType.WindowSystemMenuHint |
            Qt.WindowType.WindowMinMaxButtonsHint
        )
        self.setAttribute(Qt.WidgetAttribute.WA_TranslucentBackground)
        self.setAttribute(Qt.WidgetAttribute.WA_Hover)
        self.resize(1080, 680)
        
        # Enable Drag and Drop
        self.setAcceptDrops(True)
        
        # State tracking
        self.is_fullscreen = False
        self.is_maximized = False
        self.hud_visible = True
        self.playlist_visible = False
        self.last_volume = 0.8
        self.mouse_pos = None
        self.resizing = False
        self.resize_edge = None
        self.min_margin = 8
        self.minimum_size = QSize(480, 320)
        
        # Playlist state
        self.playlist_files = []  # List of file paths
        self.current_index = -1
        
        # Initialize components (ORDER MATTERS: media first, then UI)
        self.init_media_engine()
        self.init_ui()  # Video widget created here
        self.init_buffering_indicator()  # Must come AFTER video widget exists
        self.init_shortcuts()
        self.init_stylesheet()
        
        # Context menu
        self.setContextMenuPolicy(Qt.ContextMenuPolicy.CustomContextMenu)
        self.customContextMenuRequested.connect(self.show_main_context_menu)
        
        # Set initial window title
        self.update_window_title("StormPlayer")
        
        # Auto-hide cursor in fullscreen after 3 seconds of inactivity
        self.cursor_timer = QTimer()
        self.cursor_timer.setSingleShot(True)
        self.cursor_timer.timeout.connect(self.hide_cursor_in_fullscreen)
    
    def init_buffering_indicator(self):
        """Initialize buffering indicator AFTER video widget exists"""
        from PyQt6.QtWidgets import QProgressBar
        
        self.buffering_progress = QProgressBar(self.video_widget)
        self.buffering_progress.setRange(0, 100)
        self.buffering_progress.setTextVisible(False)
        self.buffering_progress.setFixedHeight(4)
        self.buffering_progress.hide()
        self.buffering_progress.setStyleSheet(f"""
            QProgressBar {{
                border: none;
                background-color: {BG_DARKER};
                border-radius: 2px;
            }}
            QProgressBar::chunk {{
                background-color: {FG_PURPLE};
                border-radius: 2px;
            }}
        """)
        self.buffering_progress.move(0, 0)
        self.buffering_progress.resize(self.video_widget.width(), 4)
    
    def init_stylesheet(self):
        """Apply Dracula theme styling"""
        self.setStyleSheet(STYLING)
        
        # Set application palette for consistent theming
        palette = QPalette()
        palette.setColor(QPalette.ColorRole.Window, QColor(BG_DARK))
        palette.setColor(QPalette.ColorRole.WindowText, QColor(FG_DEFAULT))
        palette.setColor(QPalette.ColorRole.Base, QColor(BG_DARKER))
        palette.setColor(QPalette.ColorRole.AlternateBase, QColor(BG_SELECTION))
        palette.setColor(QPalette.ColorRole.ToolTipBase, QColor(BG_DARK))
        palette.setColor(QPalette.ColorRole.ToolTipText, QColor(FG_DEFAULT))
        palette.setColor(QPalette.ColorRole.Text, QColor(FG_DEFAULT))
        palette.setColor(QPalette.ColorRole.Button, QColor(BG_DARKER))
        palette.setColor(QPalette.ColorRole.ButtonText, QColor(FG_DEFAULT))
        palette.setColor(QPalette.ColorRole.BrightText, QColor(FG_RED))
        palette.setColor(QPalette.ColorRole.Highlight, QColor(FG_PURPLE))
        palette.setColor(QPalette.ColorRole.HighlightedText, QColor(FG_DEFAULT))
        palette.setColor(QPalette.ColorRole.Link, QColor(FG_CYAN))
        palette.setColor(QPalette.ColorRole.LinkVisited, QColor(FG_PINK))
        QGuiApplication.setPalette(palette)
        
    def init_media_engine(self):
        """Initialize media playback components"""
        self.player = QMediaPlayer()
        self.audio_output = QAudioOutput()
        self.player.setAudioOutput(self.audio_output)
        self.audio_output.setVolume(0.8)
        
        # Connections (note: bufferProgressChanged doesn't exist in PyQt6)
        self.player.playbackStateChanged.connect(self.on_playback_state_changed)
        self.player.positionChanged.connect(self.update_position)
        self.player.durationChanged.connect(self.update_duration)
        self.player.errorOccurred.connect(self.on_media_error)
        self.player.mediaStatusChanged.connect(self.on_media_status_changed)
        
    def init_ui(self):
        """Initialize the user interface with Dracula theme"""
        # Main frame with rounded corners
        self.main_frame = QFrame()
        self.main_frame.setObjectName("MainFrame")
        self.setCentralWidget(self.main_frame)
        
        # Main layout
        layout = QVBoxLayout(self.main_frame)
        layout.setContentsMargins(2, 2, 2, 2)
        layout.setSpacing(0)
        
        # Header bar
        self.create_header(layout)
        
        # Content area (video + playlist)
        self.create_content_area(layout)
        
        # HUD controls
        self.create_hud(layout)
        
