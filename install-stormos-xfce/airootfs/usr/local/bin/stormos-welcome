    <script>
        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        async function execCmd(cmd, title = 'StormOS') {
            showToast('Executing: ' + title);
            try {
                await fetch('/api/command', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cmd: cmd, title: title })
                });
            } catch (e) {
                console.error(e);
            }
        }

        async function openUrl(url) {
            try {
                await fetch('/api/open_url', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ url: url })
                });
            } catch (e) {
                console.error(e);
            }
        }

        function handleWebSearch(e) {
            if (e.key === 'Enter') performWebSearch();
        }

        function performWebSearch() {
            const query = document.getElementById('web-search').value.trim();
            if (!query) return;
            
            if (query.startsWith('http') || (query.includes('.') && !query.includes(' '))) {
                const url = query.startsWith('http') ? query : 'https://' + query;
                openUrl(url);
            } else {
                openUrl('https://duckduckgo.com/?q=' + encodeURIComponent(query));
            }
        }

        async function searchPackages() {
            const query = document.getElementById('pkg-query').value.trim();
            const source = document.getElementById('pkg-source').value;
            const tbody = document.getElementById('pkg-results');
            
            if (!query) return;

            tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;">Searching...</td></tr>';

            try {
                const res = await fetch('/api/packages', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ query, source })
                });
                const packages = await res.json();
                
                tbody.innerHTML = '';
                if (packages.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;">No packages found.</td></tr>';
                    return;
                }

                packages.forEach(pkg => {
                    const row = document.createElement('tr');
                    row.className = 'pkg-row';
                    const isInstalled = pkg.installed;
                    
                    row.innerHTML = `
                        <td style="font-weight:bold; color: var(--accent);">${pkg.name}</td>
                        <td style="color: var(--text-secondary); font-size:0.85rem;">${pkg.version}</td>
                        <td><span class="tag ${pkg.source.toLowerCase()}">${pkg.source}</span></td>
                        <td>
                            <button style="padding: 4px 8px; font-size: 0.8rem;" 
                                onclick="execCmd(['${pkg.source === 'pacman' ? 'sudo pacman' : 'yay'}', '-S', '--noconfirm', '${pkg.name}'])"
                                ${isInstalled ? 'disabled style="opacity:0.3;"' : ''}>
                                Install
                            </button>
                            ${isInstalled ? `<button class="danger" style="padding: 4px 8px; font-size: 0.8rem;" onclick="execCmd(['${pkg.source === 'pacman' ? 'sudo pacman' : 'yay'}', '-Rns', '${pkg.name}'])">Remove</button>` : ''}
                        </td>
                    `;
                    tbody.appendChild(row);
                });
            } catch (e) {
                tbody.innerHTML = '<tr><td colspan="4" style="text-align:center; color: #ff6b6b;">Error searching packages</td></tr>';
            }
        }
    </script>
</body>
</html>
"""

# ============================================================
# Entry Point
# ============================================================
if __name__ == '__main__':
    # Start Flask in a separate thread
    t = threading.Thread(target=app.run, kwargs={'port': 5000, 'use_reloader': False})
    t.daemon = True
    t.start()

    # Create Window
    window = webview.create_window(
        '🌩️ StormOS Hub',
        'http://127.0.0.1:5000',
        width=1200,
        height=900,
        background_color='#0a192f'
    )
    webview.start()
