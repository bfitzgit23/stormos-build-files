            ("Rank mirrors (reflector)", ["sudo", "reflector", "--latest", "20", "--protocol", "https", "--sort", "rate", "--save", "/etc/pacman.d/mirrorlist"]),
            ("Force pacman sync", ["sudo", "pacman", "-Syy"])
        ]:
            btn = QPushButton(text)
            btn.setStyleSheet("""
                QPushButton {
                    background: rgba(100, 255, 218, 0.08);
                    color: #e6f1ff;
                    border: 1px solid rgba(100, 255, 218, 0.2);
                    border-radius: 12px;
                    padding: 10px 16px;
                    text-align: left;
                }
                QPushButton:hover {
                    background: rgba(100, 255, 218, 0.15);
                    border-color: #64ffda;
                }
            """)
            btn.clicked.connect(lambda _, c=cmd: run_command(c))
            layout.addWidget(btn)
        card.setLayout(layout)
        return card

