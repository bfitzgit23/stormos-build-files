        install_btn.setObjectName("gradientButton")
        install_btn.clicked.connect(self.launch_calamares)
        install_card.layout().addWidget(install_btn)

        hint = QLabel(
            "Runs the graphical installer to install StormOS to disk."
            if self.is_live else
            "StormOS is already installed. Installer is for live ISO only."
        )
        hint.setStyleSheet(f"color: {STORM_GRAY}; font-size: 12px; margin-top: 8px;")
        hint.setWordWrap(True)
        install_card.layout().addWidget(hint)
        layout.addWidget(install_card)

        if not self.is_live:
            autocard = self.create_glass_card("🔄 Autostart")
            self.autostatus = QLabel()
            autocard.layout().addWidget(self.autostatus)

            info = QLabel(
                "Control whether this welcome app launches automatically when you log in."
            )
            info.setStyleSheet(f"color: {STORM_GRAY}; font-size: 12px;")
            info.setWordWrap(True)
            autocard.layout().addWidget(info)

            btn_layout = QHBoxLayout()
