#!/usr/bin/env python3
"""
StormOS Welcome

A modern welcome + lightweight software center for Arch-based StormOS.

Software management (GNOME Software-style basics)
- Search + browse installed items
- Install / Remove
- Update all

Backends
- Pacman (repo packages)
- Flatpak (apps)
- Snap (apps)
- AppImage (local AppImages you import)

Design goals
- Keep UI responsive by running queries in background threads.
- Run privileged install/remove/update actions in a terminal (xfce4-terminal).
"""

from __future__ import annotations

import os
# import re  # (no longer needed)
import sys
import stat
import shutil
import subprocess
import webbrowser
from dataclasses import dataclass
from pathlib import Path
from typing import Callable, Optional, List, Dict, Tuple

from PyQt6.QtCore import Qt, QObject, QThread, pyqtSignal
from PyQt6.QtGui import QIcon, QFont
from PyQt6.QtWidgets import (
    QApplication,
    QComboBox,
    QFileDialog,
    QFormLayout,
    QGroupBox,
    QHBoxLayout,
    QLabel,
    QLineEdit,
    QMainWindow,
    QMessageBox,
    QPushButton,
    QSlider,
    QSplitter,
    QStatusBar,
    QTabWidget,
    QTextEdit,
    QTreeWidget,
    QTreeWidgetItem,
    QVBoxLayout,
    QWidget,
)


# ============================================================
# DATA MODEL
# ============================================================

@dataclass
class SoftwareItem:
    name: str
    source: str  # pacman | aur | flatpak | snap | appimage
    version: str = ""
    summary: str = ""
    identifier: str = ""  # e.g. flatpak app-id, snap name, appimage path, pacman pkg
    installed: bool = False
    extra: Dict[str, str] = None

    def __post_init__(self):
        if self.extra is None:
            self.extra = {}


# ============================================================
# ASYNC HELPERS
# ============================================================

class Worker(QObject):
    finished = pyqtSignal(object, object)  # (result, error)

    def __init__(self, fn: Callable, *args, **kwargs):
        super().__init__()
        self.fn = fn
        self.args = args
        self.kwargs = kwargs

    def run(self):
        try:
            res = self.fn(*self.args, **self.kwargs)
            self.finished.emit(res, None)
        except Exception as e:
            self.finished.emit(None, e)


def run_async(parent: QWidget, fn: Callable, callback: Callable, errback: Optional[Callable] = None):
    """
    Run fn() in a background thread, call callback(result) on completion,
    or errback(error) if provided.
    """
    thread = QThread(parent)
    worker = Worker(fn)
    worker.moveToThread(thread)

    def _cleanup():
        thread.quit()
        thread.wait()
        worker.deleteLater()
        thread.deleteLater()

    def _on_finished(result, error):
        try:
            if error is None:
                callback(result)
            else:
                if errback:
                    errback(error)
                else:
                    msg = str(error).strip()
                    if not msg:
                        msg = f"{type(error).__name__}"
                    else:
                        msg = f"{type(error).__name__}: {msg}"
                    QMessageBox.warning(parent, "Error", msg)
        finally:
            _cleanup()

    thread.started.connect(worker.run)
    worker.finished.connect(_on_finished)
    thread.start()


# ============================================================
# TERMINAL / PROCESS UTILITIES
# ============================================================

def find_xfce_terminal() -> Optional[str]:
    return shutil.which("xfce4-terminal")


def run_in_terminal(cmd: List[str], title: str = "StormOS", hold: bool = True):
    """
    Run a command in xfce4-terminal.

    The user explicitly requested to avoid xterm; so we ONLY use xfce4-terminal.
    """
    term = find_xfce_terminal()
    if not term:
        raise RuntimeError("xfce4-terminal not found. Install it: sudo pacman -S xfce4-terminal")

    args = [term]
    # Keep window open if supported (nice for install logs)
    if hold:
        args += ["--hold"]
    args += ["--title", title, "--execute", *cmd]
    subprocess.Popen(args)


def run_capture(cmd: List[str], timeout: int = 120) -> Tuple[int, str, str]:
    """
    Run a command (non-interactive) and capture output.
    """
    p = subprocess.run(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        timeout=timeout,
        env={**os.environ, "LANG": "C", "LC_ALL": "C"},
    )
    return p.returncode, p.stdout, p.stderr


# ============================================================
# BACKENDS
# ============================================================

class Backend:
    name: str = "backend"

    def is_available(self) -> bool:
        raise NotImplementedError

    def list_installed(self) -> List[SoftwareItem]:
        raise NotImplementedError

    def search(self, query: str) -> List[SoftwareItem]:
        raise NotImplementedError

    def details(self, item: SoftwareItem) -> str:
        return item.summary

    def install_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return None

    def remove_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return None

    def update_all_cmd(self) -> Optional[List[str]]:
        return None

    def launch(self, item: SoftwareItem) -> Optional[str]:
        return None  # returns error msg if failed


class PacmanBackend(Backend):
    name = "pacman"

    def is_available(self) -> bool:
        return shutil.which("pacman") is not None

    def list_installed(self) -> List[SoftwareItem]:
        rc, out, err = run_capture(["pacman", "-Q"])
        if rc != 0:
            raise RuntimeError(err.strip() or "pacman -Q failed")
        items: List[SoftwareItem] = []
        for line in out.splitlines():
            parts = line.strip().split()
            if len(parts) >= 2:
                pkg, ver = parts[0], parts[1]
                items.append(SoftwareItem(name=pkg, source="pacman", version=ver, installed=True, identifier=pkg))
        return items
    def search(self, query: str) -> List[SoftwareItem]:
        # pacman -Ss prints 2 lines per pkg: header + indented description
        rc, out, err = run_capture(["pacman", "-Ss", query])
        if rc != 0 and not out.strip():
            # pacman returns 1 if no matches
            return []

        items: List[SoftwareItem] = []
        lines = out.splitlines()
        i = 0
        while i < len(lines):
            header = lines[i].strip()
            desc = ""
            if i + 1 < len(lines) and lines[i + 1].startswith("    "):
                desc = lines[i + 1].strip()
                i += 2
            else:
                i += 1

            # header example: "extra/firefox 123.0-1 [installed]"
            # Parse without regex to avoid PatternError on unusual strings.
            if "/" not in header:
                continue
            repo, rest = header.split("/", 1)
            parts = rest.split()
            if len(parts) < 2:
                continue
            pkg = parts[0]
            ver = parts[1]
            installed = "[installed]" in header.lower() or "installed" in header.lower()

            items.append(
                SoftwareItem(
                    name=pkg,
                    source="pacman",
                    version=ver,
                    summary=desc,
                    identifier=pkg,
                    installed=installed,
                    extra={"repo": repo},
                )
            )
        return items

    def details(self, item: SoftwareItem) -> str:
        # Prefer -Qi if installed, else -Si
        cmd = ["pacman", "-Qi" if item.installed else "-Si", item.identifier]
        rc, out, err = run_capture(cmd)
        if rc != 0:
            return err.strip() or "No details available."
        return out.strip()

    def install_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["sudo", "pacman", "-S", "--needed", item.identifier]

    def remove_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["sudo", "pacman", "-Rns", item.identifier]

    def update_all_cmd(self) -> Optional[List[str]]:
        return ["sudo", "pacman", "-Syu"]



class YayBackend(Backend):
    """
    AUR helper backend using yay.

    Notes:
      - Search uses `yay -Ss <query>` and filters for AUR entries (lines starting with 'aur/').
      - Installed AUR packages are approximated using `pacman -Qm` (foreign packages).
    """
    name = "aur"

    def is_available(self) -> bool:
        return shutil.which("yay") is not None

    def list_installed(self) -> List[SoftwareItem]:
        # Foreign packages (typically AUR / locally built)
        rc, out, err = run_capture(["pacman", "-Qm"])
        # pacman exits with 1 when there are no "foreign" packages; treat that as empty.
        if rc == 1:
            return []
        if rc != 0:
            # If pacman is missing/broken, we consider backend unavailable.
            raise RuntimeError(err.strip() or "pacman -Qm failed")
        items: List[SoftwareItem] = []
        for line in out.splitlines():
            parts = line.strip().split()
            if len(parts) >= 2:
                pkg, ver = parts[0], parts[1]
                items.append(SoftwareItem(name=pkg, source="aur", version=ver, installed=True, identifier=pkg))
        return items

    def search(self, query: str) -> List[SoftwareItem]:
        rc, out, err = run_capture(["yay", "-Ss", query])
        if rc != 0 and not out.strip():
            return []

        items: List[SoftwareItem] = []
        lines = out.splitlines()
        i = 0
        while i < len(lines):
            header = lines[i].strip()
            desc = ""
            if i + 1 < len(lines) and lines[i + 1].startswith(" "):
                desc = lines[i + 1].strip()
                i += 2
            else:
                i += 1

            # yay output example:
            #   aur/google-chrome  123.0-1 (+123 0.00) (Installed) ...
            #   extra/python 3.12.1-1 ...
            if header.startswith("aur/"):
                left = header.split()[0]  # aur/pkgname
                aur_pkg = left.split("/", 1)[1] if "/" in left else left
                ver = ""
                # Try to read version as 2nd token
                parts = header.split()
                if len(parts) >= 2:
                    ver = parts[1]
                items.append(
                    SoftwareItem(
                        name=aur_pkg,
                        source="aur",
                        version=ver,
                        summary=desc,
                        installed="(Installed)" in header or "Installed" in header,
                        identifier=aur_pkg,
                    )
                )
        return items

    def details(self, item: SoftwareItem) -> str:
        # Try yay -Si for info; if it fails, fall back.
        rc, out, err = run_capture(["yay", "-Si", item.identifier])
        if rc == 0 and out.strip():
            return out.strip()
        return item.summary or item.name

    def install_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        # interactive by default (yay may prompt to edit PKGBUILD etc.)
        return ["yay", "-S", item.identifier]

    def remove_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["yay", "-Rns", item.identifier]

    def update_all_cmd(self) -> Optional[List[str]]:
        # Running yay without args is equivalent to -Syu on most setups; be explicit.
        return ["yay", "-Syu"]


class FlatpakBackend(Backend):
    name = "flatpak"

    def is_available(self) -> bool:
        return shutil.which("flatpak") is not None

    def _installed_set(self) -> set[str]:
        rc, out, err = run_capture(["flatpak", "list", "--app", "--columns=application"])
        if rc != 0:
            return set()
        return {ln.strip() for ln in out.splitlines() if ln.strip()}

    def list_installed(self) -> List[SoftwareItem]:
        rc, out, err = run_capture(["flatpak", "list", "--app", "--columns=application,name,version,branch,origin"])
        if rc != 0:
            raise RuntimeError(err.strip() or "flatpak list failed")
        items: List[SoftwareItem] = []
        for line in out.splitlines():
            cols = [c.strip() for c in line.split("\\t")]
            if len(cols) < 1:
                continue
            app_id = cols[0]
            name = cols[1] if len(cols) > 1 else app_id
            ver = cols[2] if len(cols) > 2 else ""
            origin = cols[4] if len(cols) > 4 else ""
            items.append(
                SoftwareItem(
                    name=name,
                    source="flatpak",
                    version=ver,
                    summary=f"{app_id} ({origin})",
                    identifier=app_id,
                    installed=True,
                    extra={"origin": origin},
                )
            )
        return items

    def search(self, query: str) -> List[SoftwareItem]:
        installed = self._installed_set()
        # Columns vary by flatpak version; these are common.
        rc, out, err = run_capture(
            ["flatpak", "search", "--columns=application,name,description,version,branch,remotes", query],
            timeout=180,
        )
        if rc != 0 and not out.strip():
            return []
        items: List[SoftwareItem] = []
        for line in out.splitlines():
            cols = [c.strip() for c in line.split("\\t")]
            if len(cols) < 1:
                continue
            app_id = cols[0]
            name = cols[1] if len(cols) > 1 and cols[1] else app_id
            desc = cols[2] if len(cols) > 2 else ""
            ver = cols[3] if len(cols) > 3 else ""
            remotes = cols[5] if len(cols) > 5 else ""
            items.append(
                SoftwareItem(
                    name=name,
                    source="flatpak",
                    version=ver,
                    summary=desc,
                    identifier=app_id,
                    installed=app_id in installed,
                    extra={"remotes": remotes},
                )
            )
        return items

    def details(self, item: SoftwareItem) -> str:
        rc, out, err = run_capture(["flatpak", "info", item.identifier], timeout=60)
        if rc != 0:
            return err.strip() or "No details available."
        return out.strip()

    def install_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        # If user has multiple remotes, flatpak can usually infer; otherwise, they can choose in terminal.
        return ["flatpak", "install", "-y", item.identifier]

    def remove_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["flatpak", "uninstall", "-y", item.identifier]

    def update_all_cmd(self) -> Optional[List[str]]:
        return ["flatpak", "update", "-y"]


class SnapBackend(Backend):
    name = "snap"

    def is_available(self) -> bool:
        return shutil.which("snap") is not None

    def list_installed(self) -> List[SoftwareItem]:

        if not self.is_available():

            return []
        rc, out, err = run_capture(["snap", "list"], timeout=120)
        if rc != 0:
            raise RuntimeError(err.strip() or "snap list failed")
        items: List[SoftwareItem] = []
        lines = out.splitlines()
        if not lines:
            return items
        # Header: Name Version Rev Tracking Publisher Notes
        for line in lines[1:]:
            if not line.strip():
                continue
            parts = line.split()
            if len(parts) < 2:
                continue
            name = parts[0]
            ver = parts[1]
            items.append(SoftwareItem(name=name, source="snap", version=ver, installed=True, identifier=name))
        return items

    def search(self, query: str) -> List[SoftwareItem]:

        if not self.is_available():

            return []
        installed_names = {i.identifier for i in self.list_installed()} if self.is_available() else set()
        rc, out, err = run_capture(["snap", "find", "--color=never", query], timeout=120)
        if rc != 0 and not out.strip():
            return []
        lines = out.splitlines()
        if not lines:
            return []
        items: List[SoftwareItem] = []
        # Header: Name Version Publisher Notes Summary
        for line in lines[1:]:
            if not line.strip():
                continue
            parts = line.split(None, 4)
            if len(parts) < 1:
                continue
            name = parts[0]
            ver = parts[1] if len(parts) > 1 else ""
            summary = parts[4] if len(parts) > 4 else ""
            items.append(
                SoftwareItem(
                    name=name,
                    source="snap",
                    version=ver,
                    summary=summary,
                    identifier=name,
                    installed=name in installed_names,
                )
            )
        return items

    def details(self, item: SoftwareItem) -> str:

        if not self.is_available():

            return "Snap is not installed."
        rc, out, err = run_capture(["snap", "info", item.identifier], timeout=60)
        if rc != 0:
            return err.strip() or "No details available."
        return out.strip()

    def install_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        # snap typically requires root unless configured otherwise
        return ["sudo", "snap", "install", item.identifier]

    def remove_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["sudo", "snap", "remove", item.identifier]

    def update_all_cmd(self) -> Optional[List[str]]:
        return ["sudo", "snap", "refresh"]


class AppImageBackend(Backend):
    name = "appimage"

    def __init__(self, appimage_dir: Path):
        self.appimage_dir = appimage_dir.expanduser()
        self.appimage_dir.mkdir(parents=True, exist_ok=True)

    def is_available(self) -> bool:
        # Always available (local file management)
        return True

    def _scan(self) -> List[SoftwareItem]:
        items: List[SoftwareItem] = []
        for p in sorted(self.appimage_dir.glob("*.AppImage")):
            items.append(
                SoftwareItem(
                    name=p.stem,
                    source="appimage",
                    version="",
                    summary=str(p),
                    identifier=str(p),
                    installed=True,
                )
            )
        return items

    def list_installed(self) -> List[SoftwareItem]:
        return self._scan()

    def search(self, query: str) -> List[SoftwareItem]:
        q = query.lower().strip()
        if not q:
            return self._scan()
        return [i for i in self._scan() if q in i.name.lower() or q in i.identifier.lower()]

    def details(self, item: SoftwareItem) -> str:
        p = Path(item.identifier)
        if not p.exists():
            return "File not found."
        try:
            st = p.stat()
            size_mb = st.st_size / (1024 * 1024)
            mode = "executable" if (st.st_mode & stat.S_IXUSR) else "not executable"
            return f"AppImage: {p.name}\nPath: {p}\nSize: {size_mb:.1f} MiB\nStatus: {mode}"
        except Exception as e:
            return str(e)

    def install_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return None  # handled via import UI

    def remove_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return None  # handled directly (delete file)

    def update_all_cmd(self) -> Optional[List[str]]:
        return None  # no global update without AppImageUpdate tooling

    def launch(self, item: SoftwareItem) -> Optional[str]:
        p = Path(item.identifier)
        if not p.exists():
            return "AppImage file not found."
        try:
            # ensure executable
            st = p.stat()
            if not (st.st_mode & stat.S_IXUSR):
                p.chmod(st.st_mode | stat.S_IXUSR)
            subprocess.Popen([str(p)])
            return None
        except Exception as e:
            return str(e)

    def import_appimage(self, src_path: str) -> SoftwareItem:
        src = Path(src_path).expanduser()
        if not src.exists():
            raise FileNotFoundError(str(src))
        if src.suffix.lower() != ".appimage":
            raise RuntimeError("Selected file is not an .AppImage")
        dst = self.appimage_dir / src.name
        if dst.exists():
            raise RuntimeError("An AppImage with this name already exists in the AppImages folder.")
        shutil.copy2(src, dst)
        st = dst.stat()
        dst.chmod(st.st_mode | stat.S_IXUSR)
        return SoftwareItem(
            name=dst.stem, source="appimage", summary=str(dst), identifier=str(dst), installed=True
        )

    def delete_appimage(self, item: SoftwareItem):
        p = Path(item.identifier)
        if p.exists():
            p.unlink()


# ============================================================
# SOFTWARE TAB UI
# ============================================================

SOURCE_LABELS = {
    "all": "All",
    "pacman": "Pacman",
    "aur": "AUR (yay)",
    "flatpak": "Flatpak",
    "snap": "Snap",
    "appimage": "AppImage",
}


class SoftwareCenter(QWidget):
    def __init__(self, status_cb: Callable[[str], None]):
        super().__init__()
        self.status_cb = status_cb

        self.appimage_backend = AppImageBackend(Path("~/.local/share/stormos/appimages"))
        self.backends: Dict[str, Backend] = {
            "pacman": PacmanBackend(),
            "aur": YayBackend(),
            "flatpak": FlatpakBackend(),
            "snap": SnapBackend(),
            "appimage": self.appimage_backend,
        }
        self._current_items: List[SoftwareItem] = []
        self._build_ui()
        self.refresh_installed()

    # ---------------- UI ----------------

    def _build_ui(self):
        root = QVBoxLayout(self)
        root.setSpacing(12)

        header = QLabel("Software")
        header.setStyleSheet("font-size:18px;color:#81A1C1; font-weight:600;")
        root.addWidget(header)

        # Backends status row
        back_row = QHBoxLayout()
        self.backends_label = QLabel(self._backend_status_text())
        self.backends_label.setStyleSheet("color:#D8DEE9;")
        back_row.addWidget(self.backends_label)
        back_row.addStretch()
        self.btn_install_missing = QPushButton("Install missing backends…")
        self.btn_install_missing.setIcon(QIcon.fromTheme("system-software-install"))
        self.btn_install_missing.clicked.connect(self.show_backend_help)
        self.btn_install_missing.setStyleSheet(self._mini_button_style())
        back_row.addWidget(self.btn_install_missing)
        root.addLayout(back_row)

        # Controls
        controls = QHBoxLayout()
        self.search_box = QLineEdit()
        self.search_box.setPlaceholderText("Search for apps and packages…")
        self.search_box.returnPressed.connect(self.search)
        self.source_combo = QComboBox()
        self.source_combo.addItem(SOURCE_LABELS["all"], "all")
        for k in ("pacman", "aur", "flatpak", "snap", "appimage"):
            self.source_combo.addItem(SOURCE_LABELS[k], k)

        self.btn_search = QPushButton("Search")
        self.btn_search.setIcon(QIcon.fromTheme("system-search"))
        self.btn_search.clicked.connect(self.search)

        self.btn_installed = QPushButton("Installed")
        self.btn_installed.setIcon(QIcon.fromTheme("view-list-details"))
        self.btn_installed.clicked.connect(self.refresh_installed)

        self.btn_updates = QPushButton("Update all")
        self.btn_updates.setIcon(QIcon.fromTheme("system-software-update"))
        self.btn_updates.clicked.connect(self.update_all)

        self.btn_add_appimage = QPushButton("Add AppImage…")
        self.btn_add_appimage.setIcon(QIcon.fromTheme("list-add"))
        self.btn_add_appimage.clicked.connect(self.add_appimage)

        for w in (self.btn_search, self.btn_installed, self.btn_updates, self.btn_add_appimage):
            w.setStyleSheet(self._mini_button_style())

        controls.addWidget(self.search_box, 3)
        controls.addWidget(self.source_combo, 1)
        controls.addWidget(self.btn_search)
        controls.addWidget(self.btn_installed)
        controls.addWidget(self.btn_updates)
        controls.addWidget(self.btn_add_appimage)
        root.addLayout(controls)

        # Splitter: list + details
        splitter = QSplitter(Qt.Orientation.Horizontal)

        self.tree = QTreeWidget()
        self.tree.setHeaderLabels(["Name", "Source", "Version", "Status"])
        self.tree.setColumnWidth(0, 260)
        self.tree.setColumnWidth(1, 90)
        self.tree.setColumnWidth(2, 120)
        self.tree.itemSelectionChanged.connect(self.on_select)

        details_wrap = QWidget()
        details_layout = QVBoxLayout(details_wrap)
        details_layout.setContentsMargins(0, 0, 0, 0)

        self.details_title = QLabel("Select an item")
        self.details_title.setStyleSheet("font-size:16px; font-weight:600; color:#ECEFF4;")
        details_layout.addWidget(self.details_title)

        self.details_text = QTextEdit()
        self.details_text.setReadOnly(True)
        self.details_text.setMinimumHeight(220)
        self.details_text.setStyleSheet("border: 1px solid #4C566A; border-radius:8px;")
        details_layout.addWidget(self.details_text, 1)

        btn_row = QHBoxLayout()
        self.btn_install = QPushButton("Install")
        self.btn_install.setIcon(QIcon.fromTheme("list-add"))
        self.btn_install.clicked.connect(self.install_selected)
        self.btn_remove = QPushButton("Remove")
        self.btn_remove.setIcon(QIcon.fromTheme("list-remove"))
        self.btn_remove.clicked.connect(self.remove_selected)
        self.btn_launch = QPushButton("Launch")
        self.btn_launch.setIcon(QIcon.fromTheme("system-run"))
        self.btn_launch.clicked.connect(self.launch_selected)

        for b in (self.btn_install, self.btn_remove, self.btn_launch):
            b.setStyleSheet(self._mini_button_style())

        btn_row.addWidget(self.btn_install)
        btn_row.addWidget(self.btn_remove)
        btn_row.addWidget(self.btn_launch)
        btn_row.addStretch()
        details_layout.addLayout(btn_row)

        self._set_action_buttons_enabled(False)

        splitter.addWidget(self.tree)
        splitter.addWidget(details_wrap)
        splitter.setStretchFactor(0, 2)
        splitter.setStretchFactor(1, 3)

        root.addWidget(splitter, 1)

        # Styles
        self.tree.setStyleSheet("""
            QTreeWidget { border: 1px solid #4C566A; border-radius: 10px; }
            QTreeWidget::item { padding: 6px; }
        """)

    def _mini_button_style(self) -> str:
        return """
        QPushButton {
            background-color: #3B4252;
            color: #ECEFF4;
            border: 1px solid #4C566A;
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 12px;
        }
        QPushButton:hover { background-color: #434C5E; border-color:#81A1C1; }
        QPushButton:pressed { background-color: #2E3440; }
        """

    def _backend_status_text(self) -> str:
        parts = []
        for key in ("pacman", "aur", "flatpak", "snap", "appimage"):
            ok = self.backends[key].is_available()
            parts.append(f"{SOURCE_LABELS[key]}: {'✓' if ok else '✕'}")
        return " · ".join(parts)

    def show_backend_help(self):
        msg = (
            "Backends install hints (Arch):\\n\\n"
            "• AUR (yay):  sudo pacman -S --needed git base-devel && git clone https://aur.archlinux.org/yay.git && cd yay && makepkg -si\\n\\n"
            "• Flatpak:    sudo pacman -S flatpak\\n"
            "  Then add Flathub: flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo\\n\\n"
            "• Snap:       sudo pacman -S snapd\\n"
            "  Enable socket: sudo systemctl enable --now snapd.socket\\n"
            "  (Some setups also need: sudo ln -s /var/lib/snapd/snap /snap)\\n\\n"
            "• AppImage:   no daemon needed — use “Add AppImage…” to import.\\n\\n"
            "• Terminal:   sudo pacman -S xfce4-terminal\\n"
        )
        QMessageBox.information(self, "Install backends", msg)

    # ---------------- Data population ----------------


    def _clear(self):
        self.tree.clear()
        self._current_items = []
        self.details_title.setText("Select an item")
        self.details_text.setText("")
        self._set_action_buttons_enabled(False)

    def _populate(self, items: List[SoftwareItem], headline: str):
        self._current_items = items
        self.tree.clear()
        self.details_title.setText(headline)
        self.details_text.setText("Select an item to see details.")

        for idx, item in enumerate(items):
            status = "Installed" if item.installed else "Available"
            it = QTreeWidgetItem([item.name, SOURCE_LABELS.get(item.source, item.source), item.version, status])
            it.setData(0, Qt.ItemDataRole.UserRole, idx)
            self.tree.addTopLevelItem(it)

        self.backends_label.setText(self._backend_status_text())
        self.status_cb(f"{len(items)} item(s)")

    # ---------------- Actions ----------------

    def refresh_installed(self):
        self._clear()
        self.status_cb("Loading installed software…")

        def _work():
            items: List[SoftwareItem] = []
            for key, backend in self.backends.items():
                if not backend.is_available():
                    continue
                # AppImage installed always fine
                items.extend(backend.list_installed())
            # sort by name
            items.sort(key=lambda x: (x.source, x.name.lower()))
            return items

        run_async(self, _work, lambda res: self._populate(res, "Installed software"))

    def search(self):
        query = self.search_box.text().strip()
        if not query:
            self.refresh_installed()
            return

        src = self.source_combo.currentData()
        self._clear()
        self.status_cb("Searching…")

        def _work():
            results: List[SoftwareItem] = []
            keys = ["pacman", "aur", "flatpak", "snap", "appimage"] if src == "all" else [src]
            for key in keys:
                backend = self.backends.get(key)
                if backend and backend.is_available():
                    results.extend(backend.search(query))
            # Prefer installed at top, then name
            results.sort(key=lambda x: (not x.installed, x.source, x.name.lower()))
            return results

        run_async(self, _work, lambda res: self._populate(res, f"Search results for “{query}”"))

    def on_select(self):
        sel = self.tree.selectedItems()
        if not sel:
            self._set_action_buttons_enabled(False)
            return
        idx = sel[0].data(0, Qt.ItemDataRole.UserRole)
        if idx is None:
            self._set_action_buttons_enabled(False)
            return
        item = self._current_items[int(idx)]
        self.details_title.setText(f"{item.name}  —  {SOURCE_LABELS.get(item.source, item.source)}")
        self.details_text.setText("Loading details…")
        self._update_action_buttons(item, details_loaded=False)

        backend = self.backends[item.source]

        def _work():
            return backend.details(item)

        def _done(text: str):
            self.details_text.setText(text)
            self._update_action_buttons(item, details_loaded=True)

        run_async(self, _work, _done)

    def _set_action_buttons_enabled(self, enabled: bool):
        self.btn_install.setEnabled(enabled)
        self.btn_remove.setEnabled(enabled)
        self.btn_launch.setEnabled(enabled)

    def _update_action_buttons(self, item: SoftwareItem, details_loaded: bool):
        backend = self.backends[item.source]
        # Install/remove for AppImage handled by import/delete/launch
        if item.source == "appimage":
            self.btn_install.setEnabled(False)
            self.btn_remove.setEnabled(True)
            self.btn_launch.setEnabled(True)
            return

        self.btn_install.setEnabled(not item.installed and backend.install_cmd(item) is not None)
        self.btn_remove.setEnabled(item.installed and backend.remove_cmd(item) is not None)
        self.btn_launch.setEnabled(False)  # repo/flatpak/snap launching is desktop-specific; keep simple.

    def _selected_item(self) -> Optional[SoftwareItem]:
        sel = self.tree.selectedItems()
        if not sel:
            return None
        idx = sel[0].data(0, Qt.ItemDataRole.UserRole)
        if idx is None:
            return None
        try:
            return self._current_items[int(idx)]
        except Exception:
            return None

    def install_selected(self):
        item = self._selected_item()
        if not item:
            return
        backend = self.backends[item.source]
        cmd = backend.install_cmd(item)
        if not cmd:
            return

        try:
            run_in_terminal(cmd, title=f"Install: {item.name}")
            self.status_cb("Install started in terminal")
        except Exception as e:
            QMessageBox.warning(self, "Terminal error", str(e))

    def remove_selected(self):
        item = self._selected_item()
        if not item:
            return

        if item.source == "appimage":
            if QMessageBox.question(self, "Remove AppImage", f"Delete {item.name} AppImage?") == QMessageBox.StandardButton.Yes:
                try:
                    self.appimage_backend.delete_appimage(item)
                    self.refresh_installed()
                    self.status_cb("Removed AppImage")
                except Exception as e:
                    QMessageBox.warning(self, "Error", str(e))
            return

        backend = self.backends[item.source]
        cmd = backend.remove_cmd(item)
        if not cmd:
            return
        try:
            run_in_terminal(cmd, title=f"Remove: {item.name}")
            self.status_cb("Remove started in terminal")
        except Exception as e:
            QMessageBox.warning(self, "Terminal error", str(e))

    def update_all(self):
        cmds = []
        for key, backend in self.backends.items():
            if backend.is_available():
                c = backend.update_all_cmd()
                if c:
                    cmds.append((key, c))

        if not cmds:
            QMessageBox.information(self, "Updates", "No update backends available.")
            return

        # Run sequentially in separate terminals (simple and clear).
        for key, cmd in cmds:
            try:
                run_in_terminal(cmd, title=f"Update: {SOURCE_LABELS.get(key, key)}")
            except Exception as e:
                QMessageBox.warning(self, "Terminal error", str(e))
                return
        self.status_cb("Update(s) started in terminal")

    def add_appimage(self):
        file_path, _ = QFileDialog.getOpenFileName(
            self,
            "Select an AppImage",
            str(Path.home()),
            "AppImage Files (*.AppImage);;All Files (*)",
        )
        if not file_path:
            return
        try:
            self.appimage_backend.import_appimage(file_path)
            self.refresh_installed()
            self.status_cb("AppImage added")
        except Exception as e:
            QMessageBox.warning(self, "Error", str(e))

    def launch_selected(self):
        item = self._selected_item()
        if not item:
            return
        if item.source != "appimage":
            QMessageBox.information(self, "Launch", "Launch is currently supported for AppImages only.")
            return
        err = self.appimage_backend.launch(item)
        if err:
            QMessageBox.warning(self, "Launch failed", err)
        else:
            self.status_cb("Launched AppImage")


# ============================================================
# MAIN WINDOW
# ============================================================

class WelcomeMenu(QMainWindow):
    def __init__(self):
        super().__init__()
        self.init_ui()
        self.load_settings()

    # ---------------- UI ----------------

    def init_ui(self):
        self.setWindowTitle("StormOS Welcome")
        self.setMinimumSize(1040, 680)
        self.setWindowIcon(QIcon.fromTheme("start-here"))

        self.apply_dark_theme()

        central = QWidget()
        self.setCentralWidget(central)
        root = QVBoxLayout(central)
        root.setSpacing(16)

        root.addWidget(self.create_header())

        # Create footer early so status callbacks are safe during tab construction.
        self.footer = self.create_footer()

        self.tabs = QTabWidget()
        self.tabs.setStyleSheet(self.tab_style())
        root.addWidget(self.tabs, 1)

        self.create_welcome_tab()
        self.create_system_tab()
        self.create_software_tab()
        self.create_settings_tab()
        self.create_help_tab()

        root.addWidget(self.footer)

    # ---------------- Styles ----------------

    def button_style(self):
        return """
        QPushButton {
            background-color: #3B4252;
            color: #ECEFF4;
            border: 1px solid #4C566A;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
            text-align: left;
        }
        QPushButton:hover { background-color: #434C5E; border-color: #81A1C1; }
        QPushButton:pressed { background-color: #2E3440; }
        """

    def group_style(self):
        return """
        QGroupBox {
            border: 1px solid #4C566A;
            border-radius: 10px;
            margin-top: 12px;
            padding-top: 12px;
            font-weight: 600;
            color: #88C0D0;
        }
        QGroupBox::title {
            subcontrol-origin: margin;
            left: 14px;
            padding: 0 6px;
        }
        """

    def tab_style(self):
        return """
        QTabWidget::pane { border: none; background: #2E3440; }
        QTabBar::tab {
            background: #3B4252;
            color: #D8DEE9;
            padding: 10px 18px;
            border-radius: 8px;
            margin-right: 6px;
        }
        QTabBar::tab:selected { background: #434C5E; color: #ECEFF4; }
        """

    # ---------------- Header / Footer ----------------

    def create_header(self):
        box = QWidget()
        layout = QHBoxLayout(box)

        title = QLabel("StormOS")
        title.setFont(QFont("Inter", 26, QFont.Weight.Bold))
        title.setStyleSheet("color: #ECEFF4;")

        subtitle = QLabel("Welcome · Arch Linux")
        subtitle.setStyleSheet("color: #A3BE8C; font-size: 13px;")

        text = QVBoxLayout()
        text.addWidget(title)
        text.addWidget(subtitle)

        layout.addLayout(text)
        layout.addStretch()
        return box

    def create_footer(self):
        bar = QStatusBar()
        bar.setStyleSheet("background:#2E3440;color:#D8DEE9;")
        self.status = QLabel("Ready")
        bar.addWidget(self.status)
        bar.addPermanentWidget(QLabel("StormOS"))
        return bar

    def set_status(self, msg: str):
        # Status label is created in create_footer(); be defensive just in case.
        if hasattr(self, "status") and self.status is not None:
            self.status.setText(msg)
        else:
            try:
                self.statusBar().showMessage(msg, 5000)
            except Exception:
                pass

    # ---------------- Tabs ----------------

    def create_welcome_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)

        label = QLabel("Welcome to StormOS")
        label.setStyleSheet("font-size: 22px; color: #88C0D0;")
        layout.addWidget(label)

        desc = QLabel(
            "A refined Arch Linux experience focused on performance, elegance, and control."
        )
        desc.setStyleSheet("color:#D8DEE9;")
        desc.setWordWrap(True)
        layout.addWidget(desc)

        installer = QGroupBox("Install StormOS")
        installer.setStyleSheet(self.group_style())
        il = QVBoxLayout(installer)

        btn_install = QPushButton("Launch Installer (Calamares)")
        btn_install.setIcon(QIcon.fromTheme("system-installer"))
        btn_install.setStyleSheet(self.button_style())
        btn_install.clicked.connect(self.launch_calamares)
        il.addWidget(btn_install)

        hint = QLabel("Runs the graphical installer to install StormOS to disk.")
        hint.setStyleSheet("color:#AEB7C2;")
        hint.setWordWrap(True)
        il.addWidget(hint)

        layout.addWidget(installer)

        quick = QGroupBox("Quick Links")
        quick.setStyleSheet(self.group_style())
        ql = QVBoxLayout(quick)

        btn_wiki = QPushButton("Arch Wiki")
        btn_wiki.setIcon(QIcon.fromTheme("help-contents"))
        btn_wiki.setStyleSheet(self.button_style())
        btn_wiki.clicked.connect(lambda: webbrowser.open("https://wiki.archlinux.org"))
        ql.addWidget(btn_wiki)

        btn_forum = QPushButton("Arch Forums")
        btn_forum.setIcon(QIcon.fromTheme("internet-services"))
        btn_forum.setStyleSheet(self.button_style())
        btn_forum.clicked.connect(lambda: webbrowser.open("https://bbs.archlinux.org"))
        ql.addWidget(btn_forum)

        layout.addWidget(quick)
        layout.addStretch()
        self.tabs.addTab(tab, "Welcome")

    def create_system_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)

        group = QGroupBox("System Actions")
        group.setStyleSheet(self.group_style())
        g = QVBoxLayout(group)

        for text, cmd, icon in [
            ("Update System (pacman -Syu)", ["sudo", "pacman", "-Syu"], "system-software-update"),
            ("Reboot", ["sudo", "reboot"], "system-reboot"),
            ("Shutdown", ["sudo", "shutdown", "-h", "now"], "system-shutdown"),
        ]:
            btn = QPushButton(text)
            btn.setIcon(QIcon.fromTheme(icon))
            btn.setStyleSheet(self.button_style())
            btn.clicked.connect(lambda _, c=cmd, t=text: self.run_cmd(c, t))
            g.addWidget(btn)

        note = QLabel("Note: commands open in xfce4-terminal (required).")
        note.setStyleSheet("color:#D8DEE9; font-size: 12px;")
        g.addWidget(note)

        layout.addWidget(group)
        layout.addStretch()
        self.tabs.addTab(tab, "System")

    def create_software_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)
        self.software_center = SoftwareCenter(status_cb=self.set_status)
        layout.addWidget(self.software_center, 1)
        self.tabs.addTab(tab, "Software")

    def create_settings_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)

        appearance = QGroupBox("Appearance")
        appearance.setStyleSheet(self.group_style())
        form = QFormLayout(appearance)

        self.theme = QComboBox()
        self.theme.addItems(["Dark", "Light"])
        self.theme.currentTextChanged.connect(self.change_theme)

        self.font_slider = QSlider(Qt.Orientation.Horizontal)
        self.font_slider.setRange(10, 18)
        self.font_slider.valueChanged.connect(self.change_font)

        form.addRow("Theme", self.theme)
        form.addRow("Font Size", self.font_slider)

        layout.addWidget(appearance)

        desktop = QGroupBox("Desktop")
        desktop.setStyleSheet(self.group_style())
        d = QVBoxLayout(desktop)

        for text, cmd, icon in [
            ("Display Settings (arandr)", ["arandr"], "video-display"),
            ("Wallpaper (nitrogen)", ["nitrogen"], "preferences-desktop-wallpaper"),
            ("Network (nm-connection-editor)", ["nm-connection-editor"], "network-wireless"),
        ]:
            btn = QPushButton(text)
            btn.setIcon(QIcon.fromTheme(icon))
            btn.setStyleSheet(self.button_style())
            btn.clicked.connect(lambda _, c=cmd, t=text: self.run_cmd(c, t, hold=False))
            d.addWidget(btn)

        layout.addWidget(desktop)
        layout.addStretch()
        self.tabs.addTab(tab, "Settings")

    def create_help_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)

        group = QGroupBox("Help")
        group.setStyleSheet(self.group_style())
        g = QVBoxLayout(group)

        btn = QPushButton("Open Arch Wiki")
        btn.setIcon(QIcon.fromTheme("help-contents"))
        btn.setStyleSheet(self.button_style())
        btn.clicked.connect(lambda: webbrowser.open("https://wiki.archlinux.org"))
        g.addWidget(btn)

        btn2 = QPushButton("Report an issue")
        btn2.setIcon(QIcon.fromTheme("dialog-information"))
        btn2.setStyleSheet(self.button_style())
        btn2.clicked.connect(lambda: QMessageBox.information(self, "Issues", "Point this to your project issue tracker."))
        g.addWidget(btn2)

        layout.addWidget(group)
        layout.addStretch()
        self.tabs.addTab(tab, "Help")

    # ---------------- Helpers ----------------

    def launch_calamares(self):
        exe = shutil.which("calamares")
        if not exe:
            QMessageBox.warning(
                self,
                "Installer not found",
                "Calamares was not found on this system.\n\n"
                "On Arch-based systems you may need to install it, or include it in the ISO build.",
            )
            return

        try:
            # If already root, run directly.
            if hasattr(os, "geteuid") and os.geteuid() == 0:
                subprocess.Popen([exe])
                self.set_status("Launching Calamares…")
                return

            pkexec = shutil.which("pkexec")
            if pkexec:
                subprocess.Popen([pkexec, exe])
                self.set_status("Launching Calamares…")
                return

            # Fallback: run via sudo inside xfce4-terminal (common on live media).
            self.run_cmd(["sudo", "-E", exe], title="Calamares Installer", hold=False)
        except Exception as e:
            QMessageBox.warning(self, "Failed to launch installer", str(e))

    def run_cmd(self, cmd: List[str], title: str = "StormOS", hold: bool = True):
        try:
            run_in_terminal(cmd, title=title, hold=hold)
            self.set_status("Command started in terminal")
        except Exception as e:
            QMessageBox.warning(self, "Terminal error", str(e))

    def change_theme(self, theme: str):
        if theme == "Dark":
            self.apply_dark_theme()
        else:
            self.apply_light_theme()

    def change_font(self, size: int):
        font = self.font()
        font.setPointSize(size)
        self.setFont(font)

    def load_settings(self):
        self.theme.setCurrentText("Dark")
        self.font_slider.setValue(12)

    # ---------------- Themes ----------------

    def apply_dark_theme(self):
        self.setStyleSheet("QWidget { background:#2E3440; color:#D8DEE9; }")

    def apply_light_theme(self):
        self.setStyleSheet("QWidget { background:#F4F6F8; color:#1E1E1E; }")


# ============================================================
# ENTRY POINT
# ============================================================

def main():
    app = QApplication(sys.argv)
    app.setStyle("Fusion")
    win = WelcomeMenu()
    win.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
