# ============================================================
# UTILITIES (terminal, package backends, etc.)
# ============================================================
def find_terminal():
    for term in ["gnome-terminal", "xfce4-terminal", "xterm", "konsole"]:
        if shutil.which(term):
            return shutil.which(term)
    return None

def run_command(cmd, title="StormOS", hold=True):
    if isinstance(cmd, list):
        cmd_str = " ".join(f'"{c}"' if " " in c else c for c in cmd)
    else:
        cmd_str = cmd
    if cmd_str.startswith("sudo") and shutil.which("pkexec"):
        cmd_str = cmd_str.replace("sudo", "pkexec", 1)
        try:
            subprocess.Popen(cmd_str, shell=True, start_new_session=True,
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except Exception:
            pass
    term = find_terminal()
    if not term:
        QMessageBox.critical(None, "Terminal Error", "No terminal found. Install gnome-terminal or xfce4-terminal.")
        return False
    term_name = os.path.basename(term)
    if hold:
        shell_cmd = f'bash -c "{cmd_str}; echo; echo \'Press Enter to close...\'; read"'
    else:
        shell_cmd = f'bash -c "{cmd_str}"'
    if term_name == "gnome-terminal":
        args = [term, "--title", title, "--", "bash", "-c", shell_cmd]
    elif term_name == "xfce4-terminal":
        args = [term, "--disable-server", "--title", title, "--command", shell_cmd]
    elif term_name == "xterm":
        args = [term, "-title", title, "-e", shell_cmd]
    else:
        args = [term, "-e", shell_cmd]
    try:
        subprocess.Popen(args, start_new_session=True,
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True
    except Exception as e:
        QMessageBox.critical(None, "Terminal Error", str(e))
        return False

def run_capture(cmd):
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        return result.returncode, result.stdout, result.stderr
    except Exception:
        return 1, "", ""

def is_live_session():
    return any(Path(m).exists() for m in LIVE_MARKERS)

# ============================================================
# PACKAGE BACKENDS (for software card)
# ============================================================
class PacmanBackend:
    def search(self, query):
        rc, out, _ = run_capture(["pacman", "-Ss", query])
        if rc != 0: return []
        packages = []
        lines = out.split('\n')
        i = 0
        while i < len(lines):
            line = lines[i].strip()
            if line and not line.startswith(' '):
                parts = line.split()
                if len(parts) >= 3:
                    name = parts[1] if '/' in parts[0] else parts[0].split('/')[-1]
                    version = parts[2]
                    desc = lines[i+1].strip() if i+1 < len(lines) else ''
                    packages.append({
                        'name': name, 'version': version, 'description': desc,
                        'source': 'pacman', 'installed': 'installed' in line.lower()
                    })
            i += 1
        return packages
    def get_installed(self):
        rc, out, _ = run_capture(["pacman", "-Q"])
        if rc != 0: return []
        packages = []
        for line in out.split('\n'):
            if line.strip():
                parts = line.split()
                if len(parts) >= 2:
                    packages.append({
                        'name': parts[0], 'version': parts[1],
                        'description': '', 'source': 'pacman', 'installed': True
                    })
        return packages

class YayBackend:
    def search(self, query):
        if not shutil.which("yay"): return []
        rc, out, _ = run_capture(["yay", "-Ss", query])
        if rc != 0: return []
        packages = []
        for line in out.split('\n'):
            if line.startswith('aur/'):
                parts = line.split()
                name = parts[0].split('/')[1]
                version = parts[1] if len(parts) > 1 else ''
                packages.append({
                    'name': name, 'version': version, 'description': '',
                    'source': 'aur', 'installed': 'Installed' in line
                })
        return packages
    def get_installed(self):
        rc, out, _ = run_capture(["pacman", "-Qm"])
        if rc != 0: return []
        packages = []
        for line in out.split('\n'):
            if line.strip():
                parts = line.split()
                if len(parts) >= 2:
                    packages.append({
                        'name': parts[0], 'version': parts[1],
                        'description': '', 'source': 'aur', 'installed': True
                    })
        return packages
    def install(self, pkg):
        run_command(["yay", "-S", "--noconfirm", pkg])
    def remove(self, pkg):
        run_command(["yay", "-Rns", pkg])

# ============================================================
# MAIN HUB WINDOW (no tabs – all in one scrollable page)
# ============================================================
class StormHub(QMainWindow):
    def __init__(self):
        super().__init__()
        self.is_live = is_live_session()
        self.selected_package = None
        self.init_ui()
        self.apply_styles()
        self.setup_autostart()
        self.animate_window()

    def init_ui(self):
        self.setWindowTitle("🌩️ StormOS Hub")
        self.setMinimumSize(1100, 800)
        screen = QGuiApplication.primaryScreen().geometry()
        self.setGeometry(
            (screen.width() - 1100) // 2,
            (screen.height() - 800) // 2,
            1100, 800
        )

        # Main container with glass background
        central = QWidget()
        central.setObjectName("central")
        self.setCentralWidget(central)
        main_layout = QVBoxLayout(central)
        main_layout.setContentsMargins(20, 20, 20, 20)
        main_layout.setSpacing(20)

        # Header
        main_layout.addWidget(self.create_header())

        # Scrollable content area
        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setFrameShape(QFrame.Shape.NoFrame)
        scroll.setStyleSheet("background: transparent; border: none;")
        content = QWidget()
        content_layout = QVBoxLayout(content)
        content_layout.setSpacing(30)
        content_layout.setContentsMargins(0, 10, 0, 30)

        # ----- NEXUS STYLE SEARCH & STREAMING (top section) -----
        content_layout.addWidget(self.create_search_section())
        content_layout.addWidget(self.create_streaming_section())
        content_layout.addWidget(self.create_learn_section())

        # ----- SYSTEM TOOLS (cards) -----
        content_layout.addWidget(self.create_system_card())
        content_layout.addWidget(self.create_software_card())
        content_layout.addWidget(self.create_maintenance_card())
        content_layout.addWidget(self.create_drivers_card())
        content_layout.addWidget(self.create_tweaks_card())
        content_layout.addWidget(self.create_gaming_card())
        content_layout.addWidget(self.create_settings_card())
        content_layout.addWidget(self.create_help_card())

        scroll.setWidget(content)
        main_layout.addWidget(scroll)

        # Footer
        main_layout.addWidget(self.create_footer())

    # ------------------------------------------------------------------
    # NEXUS‑STYLE SECTIONS
    # ------------------------------------------------------------------
    def create_search_section(self):
        card = self.create_glass_card("NEXUS SEARCH")
        layout = QVBoxLayout()
        self.search_bar = QLineEdit()
        self.search_bar.setPlaceholderText("Search the web or enter a URL...")
        self.search_bar.setObjectName("nexusSearch")
        self.search_bar.returnPressed.connect(self.do_search)
        layout.addWidget(self.search_bar)

        go_btn = QPushButton("Go")
        go_btn.setObjectName("gradientButton")
        go_btn.setFixedWidth(100)
        go_btn.clicked.connect(self.do_search)
        layout.addWidget(go_btn, alignment=Qt.AlignmentFlag.AlignRight)
        card.layout().addLayout(layout)
        return card

    def do_search(self):
        query = self.search_bar.text().strip()
        if not query:
            return
        if query.startswith(("http://", "https://")):
            webbrowser.open(query)
        elif "." in query and " " not in query:
            webbrowser.open("https://" + query)
        else:
            webbrowser.open(f"https://duckduckgo.com/?q={query.replace(' ', '+')}")

    def create_streaming_section(self):
        card = self.create_glass_card("FREE STREAMING")
        layout = QVBoxLayout()
        sites = [
            ("Tubi", "https://tubitv.com", "Movies & TV, free with ads"),
            ("Pluto TV", "https://pluto.tv", "Live channels & on-demand"),
            ("Crackle", "https://crackle.com", "Sony free movies & shows"),
            ("Roku Channel", "https://therokuchannel.roku.com", "Free shows & movies"),
            ("Plex", "https://watch.plex.tv", "Free streaming + your media"),
            ("Xumo Play", "https://xumo.tv", "Live TV and movies"),
            ("Sling Freestream", "https://watch.sling.com", "Free live & on-demand")
        ]
        for name, url, desc in sites:
            row = QHBoxLayout()
            btn = QPushButton(name)
            btn.setObjectName("streamButton")
            btn.clicked.connect(lambda checked, u=url: webbrowser.open(u))
            row.addWidget(btn)
            lbl = QLabel(desc)
            lbl.setStyleSheet(f"color: {STORM_GRAY}; font-size: 12px;")
            row.addWidget(lbl)
            row.addStretch()
            layout.addLayout(row)
        card.layout().addLayout(layout)
        return card

