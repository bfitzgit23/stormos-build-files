        theme_layout.addWidget(QLabel("Theme:"))
        self.theme_combo = QComboBox()
        self.theme_combo.addItems(["Dark (Glass)", "Light"])
        self.theme_combo.currentTextChanged.connect(self.change_theme)
        theme_layout.addWidget(self.theme_combo)
        theme_layout.addStretch()
        appearance_card.layout().addLayout(theme_layout)
        layout.addWidget(appearance_card)
        tools_card = self.create_glass_card("🖥️ Desktop Tools")
        for text, cmd in [
            ("Display Settings (arandr)", ["arandr"]),
            ("Wallpaper (nitrogen)", ["nitrogen"]),
            ("Network (nm-connection-editor)", ["nm-connection-editor"])
        ]:
            btn = QPushButton(text)
            btn.setObjectName("actionButton")
            btn.clicked.connect(lambda _, c=cmd: run_command(c, hold=False))
            tools_card.layout().addWidget(btn)
        layout.addWidget(tools_card)
        layout.addStretch()
        return tab

    def create_help_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)
        layout.setContentsMargins(30, 30, 30, 30)
        layout.setSpacing(20)
        help_card = self.create_glass_card("📚 Help & Resources")
        for name, url in [("Arch Wiki", "https://wiki.archlinux.org"), ("Arch Forums", "https://bbs.archlinux.org")]:
            btn = QPushButton(name)
            btn.setObjectName("linkButton")
            btn.clicked.connect(lambda checked, u=url: webbrowser.open(u))
            help_card.layout().addWidget(btn)
        about_btn = QPushButton("About StormOS")
        about_btn.setObjectName("linkButton")
        about_btn.clicked.connect(lambda: QMessageBox.about(self, "About StormOS", "StormOS Welcome v2.0\n\nBuilt with PyQt6"))
        help_card.layout().addWidget(about_btn)
        layout.addWidget(help_card)
        layout.addStretch()
        return tab

    # ------------------------------------------------------------------
    # Actions
    # ------------------------------------------------------------------
    def launch_calamares(self):
        if not shutil.which("calamares"):
            QMessageBox.warning(self, "Installer not found", "Calamares not installed.")
            return
        run_command(["calamares"], "Calamares Installer", hold=False)

    def enable_autostart(self):
        AUTOSTART_FILE.parent.mkdir(parents=True, exist_ok=True)
        AUTOSTART_FILE.write_text("""[Desktop Entry]
Type=Application
Name=StormOS Welcome
Exec=stormos-welcome
Icon=stormos-welcome
Comment=StormOS Welcome Screen
X-GNOME-Autostart-enabled=true
Terminal=false
Categories=System;
""")
        if AUTOSTART_DISABLED_MARKER.exists():
            AUTOSTART_DISABLED_MARKER.unlink()
        self.update_autostart_status()
        self.status_label.setText("Autostart enabled")

    def disable_autostart(self):
        if AUTOSTART_FILE.exists():
            AUTOSTART_FILE.unlink()
        AUTOSTART_DISABLED_MARKER.touch()
        self.update_autostart_status()
        self.status_label.setText("Autostart disabled")

    def update_autostart_status(self):
        if not hasattr(self, 'autostatus'):
            return
        if AUTOSTART_FILE.exists() and not AUTOSTART_DISABLED_MARKER.exists():
            self.autostatus.setText("✓ Autostart is currently ENABLED")
            self.autostatus.setStyleSheet(f"color: {STORM_TEAL}; margin-bottom: 8px;")
        else:
            self.autostatus.setText("✗ Autostart is currently DISABLED")
            self.autostatus.setStyleSheet(f"color: {STORM_CORAL}; margin-bottom: 8px;")

    def change_theme(self, theme):
        if "Dark" in theme:
            self.apply_styles()
        else:
            self.setStyleSheet("QMainWindow { background-color: #f0f0f0; } QLabel { color: #000; }")

    def setup_autostart(self):
        if not self.is_live and not AUTOSTART_DISABLED_MARKER.exists():
            QTimer.singleShot(1000, self.disable_autostart_once)

    def disable_autostart_once(self):
        if AUTOSTART_FILE.exists():
            AUTOSTART_FILE.unlink()
        AUTOSTART_DISABLED_MARKER.touch()

    def apply_styles(self):
        self.setStyleSheet(f"""
