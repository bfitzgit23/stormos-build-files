#!/usr/bin/env python3
"""
StormOS Hub – Nexus Smart Web Dashboard
Uses PyWebView + Flask for a modern Web UI with Python backend power.
"""

import sys
import os
import shutil
import subprocess
import threading
import webbrowser
from flask import Flask, request, jsonify, render_template_string
import webview

# ============================================================
# Configuration & Colors
# ============================================================
STORM_NAVY = "#0a192f"
STORM_BLUE = "#64ffda"
STORM_PURPLE = "#a742f5"
STORM_DARK = "#020c1b"
STORM_LIGHT = "#e6f1ff"

# ============================================================
# Backend Logic (Terminal & Packages)
# ============================================================

def find_terminal():
    for term in ["gnome-terminal", "xfce4-terminal", "xterm", "konsole"]:
        if shutil.which(term):
            return shutil.which(term)
    return None

def run_command(cmd, title="StormOS", hold=True):
    """Execute a command in a terminal."""
    if isinstance(cmd, list):
        cmd_str = " ".join(f'"{c}"' if " " in c else c for c in cmd)
    else:
        cmd_str = cmd

    if cmd_str.startswith("sudo") and shutil.which("pkexec"):
        cmd_str = cmd_str.replace("sudo", "pkexec", 1)
        try:
            subprocess.Popen(cmd_str, shell=True, start_new_session=True,
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except Exception:
            pass

    term = find_terminal()
    if not term: return False

    term_name = os.path.basename(term)
    shell_cmd = f'bash -c "{cmd_str}; echo; echo \'Press Enter to close...\'; read"' if hold else f'bash -c "{cmd_str}"'

    if term_name == "gnome-terminal":
        args = [term, "--title", title, "--", "bash", "-c", shell_cmd]
    elif term_name == "xfce4-terminal":
        args = [term, "--disable-server", "--title", title, "--command", shell_cmd]
    elif term_name == "xterm":
        args = [term, "-title", title, "-e", shell_cmd]
    else:
        args = [term, "-e", shell_cmd]

    try:
        subprocess.Popen(args, start_new_session=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True
    except Exception:
        return False

def run_capture(cmd):
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
        return result.returncode, result.stdout, result.stderr
    except Exception:
        return 1, "", ""

def search_pacman(query):
    rc, out, _ = run_capture(["pacman", "-Ss", query])
    if rc != 0: return []
    packages = []
    lines = out.split('\n')
    for i, line in enumerate(lines):
        if line.strip() and not line.startswith(' '):
            parts = line.split()
            if len(parts) >= 2:
                name = parts[1] if '/' in parts[0] else parts[0].split('/')[-1]
                version = parts[2] if len(parts) > 2 else ''
                desc = lines[i+1].strip() if i+1 < len(lines) else ''
                packages.append({
                    'name': name, 'version': version, 'description': desc,
                    'source': 'pacman', 'installed': 'installed' in line.lower()
                })
    return packages

def search_aur(query):
    if not shutil.which("yay"): return []
    rc, out, _ = run_capture(["yay", "-Ss", query])
    if rc != 0: return []
    packages = []
    for line in out.split('\n'):
        if line.startswith('aur/'):
            parts = line.split()
            name = parts[0].split('/')[1]
            version = parts[1] if len(parts) > 1 else ''
            packages.append({
                'name': name, 'version': version, 'description': '',
                'source': 'aur', 'installed': 'Installed' in line
            })
    return packages

# ============================================================
# Flask Server (API Bridge)
# ============================================================
app = Flask(__name__)

@app.route('/')
def index():
    # Injecting the HTML/CSS/JS directly here for a single-file solution
    return render_template_string(HTML_TEMPLATE)

@app.route('/api/command', methods=['POST'])
def execute_command():
    data = request.json
    cmd = data.get('cmd')
    title = data.get('title', 'StormOS')
    success = run_command(cmd, title)
    return jsonify({'status': 'started' if success else 'failed'})

@app.route('/api/packages', methods=['POST'])
def get_packages():
    data = request.json
    query = data.get('query', '')
    source = data.get('source', 'All')
    
    pkgs = []
    if source in ["All", "Pacman"]:
        pkgs.extend(search_pacman(query))
    if source in ["All", "AUR"]:
        pkgs.extend(search_aur(query))
        
    return jsonify(pkgs)

@app.route('/api/open_url', methods=['POST'])
def open_url():
    data = request.json
    webbrowser.open(data.get('url'))
    return jsonify({'status': 'opened'})

