            ("Install Microsoft core fonts (AUR: ttf-ms-fonts)",
             ["yay", "-S", "ttf-ms-fonts"]),
            ("Install Google Noto fonts",
             ["sudo", "pacman", "-S", "--needed", "noto-fonts",
              "noto-fonts-cjk", "noto-fonts-emoji", "noto-fonts-extra"]),
            ("Rebuild font cache",
             ["fc-cache", "-fv"]),
        ]:
