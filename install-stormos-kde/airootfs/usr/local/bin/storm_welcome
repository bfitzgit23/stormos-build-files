# ============================================================
# TERMINAL / PROCESS UTILITIES (FIXED)
# ============================================================

def find_available_terminal() -> Optional[str]:
    """Find any available terminal emulator."""
    terminals = ["xfce4-terminal", "xterm", "gnome-terminal", "konsole", "alacritty", "kitty"]
    for term in terminals:
        path = shutil.which(term)
        if path:
            return path
    return None


def run_in_terminal(cmd: List[str], title: str = "StormOS", hold: bool = True):
    """
    Launch a command in a new terminal window.
    Uses xfce4-terminal if available, otherwise falls back to xterm.
    """
    term = find_available_terminal()
    if not term:
        raise RuntimeError(
            "No terminal emulator found.\n"
            "Install xfce4-terminal:  sudo pacman -S xfce4-terminal"
        )
    
    # Build terminal arguments based on the terminal type
    term_name = os.path.basename(term)
    args = [term]
    
    if term_name == "xfce4-terminal":
        args += ["--disable-server"]  # Prevent issues with existing instances
        if hold:
            args += ["--hold"]
        args += ["--title", title, "--execute"] + cmd
    elif term_name == "xterm":
        if hold:
            # xterm: keep open by adding a shell read at the end
            cmd_with_hold = cmd + [";", "echo", "Press Enter to close...", ";", "read"]
            args += ["-title", title, "-e", " ".join(cmd_with_hold)]
        else:
            args += ["-title", title, "-e"] + cmd
    elif term_name == "gnome-terminal":
        if hold:
            args += ["--title", title, "--", "bash", "-c", " ".join(cmd) + "; exec bash"]
        else:
            args += ["--title", title, "--"] + cmd
    else:
        # Generic fallback: try to use --execute or -e
        if "--execute" in args or "-e" in args:
            args += cmd
        else:
            args += ["-e"] + cmd
    
    # Set DISPLAY environment variable to ensure terminal shows on correct screen
    env = os.environ.copy()
    if "DISPLAY" not in env:
        env["DISPLAY"] = ":0"
    
    # Detach the process so it doesn't close with the parent
    subprocess.Popen(args, env=env, start_new_session=True)


# Inside WelcomeMenu class, replace run_cmd with:
def run_cmd(self, cmd: List[str], title: str = "StormOS", hold: bool = True):
    """Run a command, using pkexec for sudo if available and graphical."""
    # If the command uses sudo and pkexec exists, use pkexec for graphical password prompt
    if cmd[0] == "sudo" and shutil.which("pkexec"):
        # Replace 'sudo' with 'pkexec' and remove the 'sudo' argument
        pkexec_cmd = ["pkexec"] + cmd[1:]
        try:
            # Run pkexec directly (it will show its own GUI)
            subprocess.Popen(pkexec_cmd, start_new_session=True)
            self.set_status(f"Running {cmd[1]} with elevated privileges...")
            return
        except Exception as e:
            # Fall back to terminal if pkexec fails
            pass
    
    # Fallback: run in terminal
    try:
        run_in_terminal(cmd, title=title, hold=hold)
        self.set_status("Command started in terminal")
    except Exception as e:
        QMessageBox.warning(self, "Terminal error", str(e))
