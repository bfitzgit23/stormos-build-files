            badge = QLabel(" LIVE SESSION ")
            badge.setStyleSheet(f"background: {STORM_CORAL}; color: {STORM_DARK}; padding: 4px 12px; border-radius: 20px; font-weight: bold;")
            hlayout.addWidget(badge)
        return header

