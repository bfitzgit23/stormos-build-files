    def do_search(self):
        query = self.search_bar.text().strip()
        if not query:
            return
        # If it looks like a URL, open it; else search with DuckDuckGo
        if query.startswith(("http://", "https://")):
            webbrowser.open(query)
        elif "." in query and " " not in query:
            webbrowser.open("https://" + query)
        else:
            webbrowser.open(f"https://duckduckgo.com/?q={query.replace(' ', '+')}")

    # ------------------------------------------------------------------
    # All other tabs (System, Software, Maintenance, Drivers, Tweaks, Gaming, Settings, Help)
    # remain exactly as in your original app – I include minimal versions here for completeness.
    # (For brevity, I reuse the same methods from previous working code.)
    # ------------------------------------------------------------------
    def create_system_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)
        layout.setContentsMargins(30, 30, 30, 30)
        card = self.create_glass_card("⚡ System Actions")
        for text, cmd in [
            ("⟳ Update System (pacman -Syu)", ["sudo", "pacman", "-Syu"]),
            ("⟳ Update System + AUR (yay -Syu)", ["yay", "-Syu"]),
            ("🔁 Reboot", ["sudo", "reboot"]),
            ("⏻ Shutdown", ["sudo", "shutdown", "-h", "now"])
        ]:
            btn = QPushButton(text)
            btn.setObjectName("actionButton")
            btn.clicked.connect(lambda _, c=cmd, t=text: run_command(c, t))
            card.layout().addWidget(btn)
        layout.addWidget(card)
        layout.addStretch()
        return tab

    def create_software_tab(self):
        # Simplified software center – same as original working version
        tab = QWidget()
        layout = QVBoxLayout(tab)
        layout.setContentsMargins(30, 30, 30, 30)
        title = QLabel("📦 Software Center")
        title.setStyleSheet("font-size: 20px; font-weight: bold; color: #64ffda;")
        layout.addWidget(title)

        search_row = QHBoxLayout()
        self.soft_search = QLineEdit()
        self.soft_search.setPlaceholderText("Search packages...")
        self.soft_search.setObjectName("glassInput")
        search_row.addWidget(self.soft_search)
        self.soft_source = QComboBox()
        self.soft_source.addItems(["All", "Pacman", "AUR"])
        search_row.addWidget(self.soft_source)
        search_btn = QPushButton("Search")
        search_btn.setObjectName("smallGlass")
        search_btn.clicked.connect(self.search_packages)
        search_row.addWidget(search_btn)
        layout.addLayout(search_row)

        splitter = QSplitter(Qt.Orientation.Horizontal)
        self.package_list = QTreeWidget()
        self.package_list.setHeaderLabels(["Name", "Version", "Source"])
        splitter.addWidget(self.package_list)
        details = QWidget()
        details_layout = QVBoxLayout(details)
        self.details_title = QLabel("Select a package")
        self.details_title.setStyleSheet("font-weight: bold;")
        details_layout.addWidget(self.details_title)
        self.details_text = QTextEdit()
        self.details_text.setReadOnly(True)
        details_layout.addWidget(self.details_text)
        btn_row = QHBoxLayout()
        self.install_btn = QPushButton("Install")
        self.install_btn.clicked.connect(self.install_package)
        self.remove_btn = QPushButton("Remove")
        self.remove_btn.clicked.connect(self.remove_package)
        btn_row.addWidget(self.install_btn)
        btn_row.addWidget(self.remove_btn)
        details_layout.addLayout(btn_row)
        splitter.addWidget(details)
        layout.addWidget(splitter)
        return tab

    def search_packages(self):
        query = self.soft_search.text().strip()
        if not query: return
        self.package_list.clear()
        threading.Thread(target=self._do_search, args=(query, self.soft_source.currentText()), daemon=True).start()

    def _do_search(self, query, source):
        packages = []
        if source in ["All", "Pacman"]:
            packages.extend(PacmanBackend().search(query))
        if source in ["All", "AUR"] and shutil.which("yay"):
            packages.extend(YayBackend().search(query))
        QApplication.instance().postEvent(self, SearchResultsEvent(packages))

    def install_package(self):
        if not hasattr(self, 'selected_pkg'): return
        pkg = self.selected_pkg
        if pkg['source'] == 'pacman':
            run_command(["sudo", "pacman", "-S", "--noconfirm", pkg['name']])
        else:
            run_command(["yay", "-S", "--noconfirm", pkg['name']])

    def remove_package(self):
        if not hasattr(self, 'selected_pkg'): return
        pkg = self.selected_pkg
        if pkg['source'] == 'pacman':
            run_command(["sudo", "pacman", "-Rns", pkg['name']])
        else:
            run_command(["yay", "-Rns", pkg['name']])

    def customEvent(self, event):
        if isinstance(event, SearchResultsEvent):
            self.package_list.clear()
            for pkg in event.packages:
                item = QTreeWidgetItem([pkg['name'], pkg['version'], pkg['source']])
                item.setData(0, Qt.ItemDataRole.UserRole, pkg)
                self.package_list.addTopLevelItem(item)
            self.package_list.itemClicked.connect(lambda it, col: setattr(self, 'selected_pkg', it.data(0, Qt.ItemDataRole.UserRole)))

