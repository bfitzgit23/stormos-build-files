def main():
    log("=== Starting StormOS Hub ===")
    app = QApplication(sys.argv)
    app.setStyle("Fusion")
    window = StormHub()
    log("Showing window...")
    window.show()
    log("Entering event loop")
    sys.exit(app.exec())

if __name__ == "__main__":
    main()
