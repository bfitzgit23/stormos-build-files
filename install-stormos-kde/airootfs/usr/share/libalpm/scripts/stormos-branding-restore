#!/bin/bash
#
# StormOS branding restore — re-applies os-release and logo assets
# after a pacman transaction touches the filesystem package.

set -u

OS_RELEASE=/etc/os-release
LOGO_SRC=/usr/share/icons/hicolor/128x128/apps/stormos.png
LOGO_DST=/usr/share/pixmaps/stormos.png

cat > "$OS_RELEASE" <<'EOF'
NAME=StormOS
VERSION="StormOS"
ID=StormOS
ID_LIKE=arch
VERSION_ID=21.7
PRETTY_NAME="StormOS"
ANSI_COLOR="0;36"
LOGO=stormos
HOME_URL="https://sourceforge.net/projects/hackman-linux"
SUPPORT_URL="https://sourceforge.net/p/hackman-linux/discussion/"
EOF

if [ -f "$LOGO_SRC" ] && [ ! -f "$LOGO_DST" ]; then
    install -Dm644 "$LOGO_SRC" "$LOGO_DST"
fi

exit 0
