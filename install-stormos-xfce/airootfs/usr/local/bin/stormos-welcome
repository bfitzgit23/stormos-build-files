    def create_system_card(self):
        card = self.create_glass_card("⚡ SYSTEM ACTIONS")
        layout = QVBoxLayout()
        actions = [
            ("⟳ Update System (pacman -Syu)", ["sudo", "pacman", "-Syu"]),
            ("⟳ Update AUR (yay -Syu)", ["yay", "-Syu"]),
            ("🔁 Reboot", ["sudo", "reboot"]),
            ("⏻ Shutdown", ["sudo", "shutdown", "-h", "now"])
        ]
        for text, cmd in actions:
            btn = QPushButton(text)
            btn.setStyleSheet("""
                QPushButton {
                    background: rgba(100, 255, 218, 0.08);
                    color: #e6f1ff;
                    border: 1px solid rgba(100, 255, 218, 0.2);
                    border-radius: 12px;
                    padding: 10px 16px;
                    text-align: left;
                }
                QPushButton:hover {
                    background: rgba(100, 255, 218, 0.15);
                    border-color: #64ffda;
                }
            """)
            btn.clicked.connect(lambda checked, c=cmd, t=text: run_command(c, t))
            layout.addWidget(btn)
        card.setLayout(layout)
        return card

    # ---------- Software Center (fully functional) ----------
    class SearchThread(QThread):
        finished = pyqtSignal(list)

        def __init__(self, query, source):
            super().__init__()
            self.query = query
            self.source = source

        def run(self):
            packages = []
            if self.source in ["All", "Pacman"]:
                packages.extend(PacmanBackend().search(self.query))
            if self.source in ["All", "AUR"] and shutil.which("yay"):
                packages.extend(YayBackend().search(self.query))
            self.finished.emit(packages)

    def create_software_card(self):
        card = self.create_glass_card("📦 SOFTWARE CENTER")
        layout = QVBoxLayout()

        # Search row
        row = QHBoxLayout()
        self.soft_search = QLineEdit()
        self.soft_search.setPlaceholderText("Search packages...")
        self.soft_search.setStyleSheet("padding: 8px; border-radius: 8px;")
        row.addWidget(self.soft_search)
        self.soft_source = QComboBox()
        self.soft_source.addItems(["All", "Pacman", "AUR"])
        row.addWidget(self.soft_source)
        search_btn = QPushButton("Search")
        search_btn.clicked.connect(self.start_package_search)
        row.addWidget(search_btn)
        layout.addLayout(row)

        # Results area
        splitter = QSplitter(Qt.Orientation.Horizontal)
        self.package_tree = QTreeWidget()
        self.package_tree.setHeaderLabels(["Name", "Version", "Source"])
        self.package_tree.setMaximumHeight(250)
        self.package_tree.itemClicked.connect(self.on_package_selected)
        splitter.addWidget(self.package_tree)

        details_widget = QWidget()
        details_layout = QVBoxLayout(details_widget)
        self.details_title = QLabel("Select a package")
        self.details_title.setStyleSheet("font-weight: bold;")
        details_layout.addWidget(self.details_title)
        self.details_text = QTextEdit()
        self.details_text.setReadOnly(True)
        self.details_text.setMaximumHeight(100)
        details_layout.addWidget(self.details_text)
        btn_row = QHBoxLayout()
        self.install_btn = QPushButton("Install")
        self.install_btn.clicked.connect(self.install_package)
        self.install_btn.setEnabled(False)
        self.remove_btn = QPushButton("Remove")
        self.remove_btn.clicked.connect(self.remove_package)
        self.remove_btn.setEnabled(False)
        btn_row.addWidget(self.install_btn)
        btn_row.addWidget(self.remove_btn)
        details_layout.addLayout(btn_row)
        splitter.addWidget(details_widget)

        layout.addWidget(splitter)
        card.setLayout(layout)
        return card

    def start_package_search(self):
        query = self.soft_search.text().strip()
        if not query:
            return
        self.package_tree.clear()
        self.search_thread = self.SearchThread(query, self.soft_source.currentText())
        self.search_thread.finished.connect(self.display_search_results)
        self.search_thread.start()

    def display_search_results(self, packages):
        self.package_tree.clear()
        for pkg in packages:
            item = QTreeWidgetItem([pkg['name'], pkg['version'], pkg['source']])
            item.setData(0, Qt.ItemDataRole.UserRole, pkg)
            self.package_tree.addTopLevelItem(item)

    def on_package_selected(self, item, col):
        pkg = item.data(0, Qt.ItemDataRole.UserRole)
        self.selected_package = pkg
        self.details_title.setText(f"{pkg['name']} — {pkg['source']}")
        self.details_text.setText(pkg.get('description', 'No description'))
        self.install_btn.setEnabled(not pkg.get('installed', False))
        self.remove_btn.setEnabled(pkg.get('installed', False))

    def install_package(self):
        if self.selected_package:
            if self.selected_package['source'] == 'pacman':
                run_command(["sudo", "pacman", "-S", "--noconfirm", self.selected_package['name']])
            else:
                run_command(["yay", "-S", "--noconfirm", self.selected_package['name']])

    def remove_package(self):
        if self.selected_package:
            if self.selected_package['source'] == 'pacman':
                run_command(["sudo", "pacman", "-Rns", self.selected_package['name']])
            else:
                run_command(["yay", "-Rns", self.selected_package['name']])

