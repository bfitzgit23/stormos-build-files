        ddg_status.setStyleSheet(f"color: {STORM_GRAY}; font-size: 11px;")
        ddg_row.addWidget(ddg_status)
        ddg_row.addStretch()
        layout.addLayout(ddg_row)

        for name, url in [("Arch Wiki", "https://wiki.archlinux.org"),
