            btn.clicked.connect(lambda _, c=cmd, t=label: self._run_cmd(c, t))
            gsh.addWidget(btn)
        layout.addWidget(g_shell)

        # ---- Boot / Plymouth ----
        g_boot = QGroupBox("Boot & Plymouth")
        g_boot.setStyleSheet(GROUP_STYLE)
        gb = QVBoxLayout(g_boot)
        for label, cmd in [
            ("Install Plymouth (animated boot splash)",
             ["sudo", "pacman", "-S", "--needed", "plymouth"]),
            ("Set Plymouth theme: bgrt (OEM logo)",
             ["bash", "-c",
              "sudo plymouth-set-default-theme -R bgrt && "
              "sudo mkinitcpio -P"]),
            ("Set Plymouth theme: spinner",
             ["bash", "-c",
              "sudo plymouth-set-default-theme -R spinner && "
