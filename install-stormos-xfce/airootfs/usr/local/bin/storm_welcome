)


# ============================================================
# CONSTANTS / PATHS
# ============================================================

AUTOSTART_PATHS = [
    Path("/etc/xdg/autostart/stormos-welcome.desktop"),
    Path.home() / ".config/autostart/stormos-welcome.desktop",
]

LIVE_MARKERS = [
    "/run/archiso",
    "/run/miso",
    "/etc/live",
    "/run/live",
]

LIVE_USERS = {"live", "liveuser", "archiso", "stormos-live"}


# ============================================================
# LIVE / INSTALLED DETECTION
# ============================================================

def is_live_session() -> bool:
    """Return True if we appear to be running inside a live ISO environment."""
    for marker in LIVE_MARKERS:
        if Path(marker).exists():
            return True
    try:
        with open("/proc/cmdline") as f:
            cmdline = f.read()
        if any(k in cmdline for k in ("boot=live", "copytoram", "archisodevice", "misodevice")):
            return True
    except OSError:
        pass
    try:
        import pwd
        user = pwd.getpwuid(os.getuid()).pw_name
        if user in LIVE_USERS:
            return True
    except Exception:
        pass
    return False


def disable_autostart():
    """
    Remove all known autostart .desktop files so the app does not
    launch again after the user has installed StormOS to disk.
    """
    removed: List[str] = []
    errors: List[str] = []
    for p in AUTOSTART_PATHS:
        if p.exists():
            try:
                p.unlink()
                removed.append(str(p))
            except PermissionError:
                # Try with sudo if we're not root
                rc = subprocess.call(
                    ["sudo", "rm", "-f", str(p)],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
                if rc == 0:
                    removed.append(str(p))
                else:
                    errors.append(str(p))
    return removed, errors


# ============================================================
# DATA MODEL
# ============================================================

@dataclass
class SoftwareItem:
    name: str
    source: str  # pacman | aur | flatpak | snap | appimage
    version: str = ""
    summary: str = ""
    identifier: str = ""
    installed: bool = False
    extra: Dict[str, str] = field(default_factory=dict)


# ============================================================
# ASYNC HELPERS
# ============================================================

class Worker(QObject):
    finished = pyqtSignal(object, object)

    def __init__(self, fn: Callable, *args, **kwargs):
        super().__init__()
        self.fn = fn
        self.args = args
        self.kwargs = kwargs

    def run(self):
        try:
            res = self.fn(*self.args, **self.kwargs)
            self.finished.emit(res, None)
        except Exception as e:
            self.finished.emit(None, e)


def run_async(parent: QWidget, fn: Callable, callback: Callable,
              errback: Optional[Callable] = None):
    thread = QThread(parent)
    worker = Worker(fn)
    worker.moveToThread(thread)

    def _cleanup():
        thread.quit()
        thread.wait()
        worker.deleteLater()
        thread.deleteLater()

    def _on_finished(result, error):
        try:
            if error is None:
                callback(result)
            else:
                if errback:
                    errback(error)
                else:
                    msg = str(error).strip() or f"{type(error).__name__}"
                    QMessageBox.warning(parent, "Error", msg)
        finally:
            _cleanup()

    thread.started.connect(worker.run)
    worker.finished.connect(_on_finished)
    thread.start()


# ============================================================
# TERMINAL / PROCESS UTILITIES
# ============================================================

def find_xfce_terminal() -> Optional[str]:
    return shutil.which("xfce4-terminal")


def run_in_terminal(cmd: List[str], title: str = "StormOS", hold: bool = True):
    term = find_xfce_terminal()
    if not term:
        raise RuntimeError(
            "xfce4-terminal not found.\n"
            "Install it first:  sudo pacman -S xfce4-terminal"
        )
    args = [term]
    if hold:
        args += ["--hold"]
    args += ["--title", title, "--execute", *cmd]
    subprocess.Popen(args)


def run_capture(cmd: List[str], timeout: int = 120) -> Tuple[int, str, str]:
    p = subprocess.run(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        timeout=timeout,
        env={**os.environ, "LANG": "C", "LC_ALL": "C"},
    )
    return p.returncode, p.stdout, p.stderr


# ============================================================
# BACKENDS (software center)
# ============================================================

class Backend:
    name: str = "backend"

    def is_available(self) -> bool:
        raise NotImplementedError

    def list_installed(self) -> List[SoftwareItem]:
        raise NotImplementedError

    def search(self, query: str) -> List[SoftwareItem]:
        raise NotImplementedError

    def details(self, item: SoftwareItem) -> str:
        return item.summary

    def install_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return None

    def remove_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return None

    def update_all_cmd(self) -> Optional[List[str]]:
        return None

    def launch(self, item: SoftwareItem) -> Optional[str]:
        return None


class PacmanBackend(Backend):
    name = "pacman"

    def is_available(self) -> bool:
        return shutil.which("pacman") is not None

    def list_installed(self) -> List[SoftwareItem]:
        rc, out, err = run_capture(["pacman", "-Q"])
        if rc != 0:
            raise RuntimeError(err.strip() or "pacman -Q failed")
        items: List[SoftwareItem] = []
        for line in out.splitlines():
            parts = line.strip().split()
            if len(parts) >= 2:
                pkg, ver = parts[0], parts[1]
                items.append(SoftwareItem(
                    name=pkg, source="pacman", version=ver,
                    installed=True, identifier=pkg
                ))
        return items

    def search(self, query: str) -> List[SoftwareItem]:
        rc, out, err = run_capture(["pacman", "-Ss", query])
        if rc != 0 and not out.strip():
            return []
        items: List[SoftwareItem] = []
        lines = out.splitlines()
        i = 0
        while i < len(lines):
            header = lines[i].strip()
            desc = ""
            if i + 1 < len(lines) and lines[i + 1].startswith("    "):
                desc = lines[i + 1].strip()
                i += 2
            else:
                i += 1
            if "/" not in header:
                continue
            repo, rest = header.split("/", 1)
            parts = rest.split()
            if len(parts) < 2:
                continue
            pkg, ver = parts[0], parts[1]
            installed = "installed" in header.lower()
            items.append(SoftwareItem(
                name=pkg, source="pacman", version=ver, summary=desc,
                identifier=pkg, installed=installed, extra={"repo": repo}
            ))
        return items

    def details(self, item: SoftwareItem) -> str:
        cmd = ["pacman", "-Qi" if item.installed else "-Si", item.identifier]
        rc, out, err = run_capture(cmd)
        return out.strip() if rc == 0 else (err.strip() or "No details available.")

    def install_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["sudo", "pacman", "-S", "--needed", item.identifier]

    def remove_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["sudo", "pacman", "-Rns", item.identifier]

    def update_all_cmd(self) -> Optional[List[str]]:
        return ["sudo", "pacman", "-Syu"]


class YayBackend(Backend):
    name = "aur"

    def is_available(self) -> bool:
        return shutil.which("yay") is not None

    def list_installed(self) -> List[SoftwareItem]:
        rc, out, err = run_capture(["pacman", "-Qm"])
        if rc == 1:
            return []
        if rc != 0:
            raise RuntimeError(err.strip() or "pacman -Qm failed")
        items: List[SoftwareItem] = []
        for line in out.splitlines():
            parts = line.strip().split()
            if len(parts) >= 2:
                pkg, ver = parts[0], parts[1]
                items.append(SoftwareItem(
                    name=pkg, source="aur", version=ver,
                    installed=True, identifier=pkg
                ))
        return items

    def search(self, query: str) -> List[SoftwareItem]:
        rc, out, err = run_capture(["yay", "-Ss", query])
        if rc != 0 and not out.strip():
            return []
        items: List[SoftwareItem] = []
        lines = out.splitlines()
        i = 0
        while i < len(lines):
            header = lines[i].strip()
            desc = ""
            if i + 1 < len(lines) and lines[i + 1].startswith(" "):
                desc = lines[i + 1].strip()
                i += 2
            else:
                i += 1
            if header.startswith("aur/"):
                left = header.split()[0]
                aur_pkg = left.split("/", 1)[1] if "/" in left else left
                parts = header.split()
                ver = parts[1] if len(parts) >= 2 else ""
                items.append(SoftwareItem(
                    name=aur_pkg, source="aur", version=ver, summary=desc,
                    installed="Installed" in header, identifier=aur_pkg,
                ))
        return items

    def details(self, item: SoftwareItem) -> str:
        rc, out, err = run_capture(["yay", "-Si", item.identifier])
        return out.strip() if rc == 0 and out.strip() else (item.summary or item.name)

    def install_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["yay", "-S", item.identifier]

    def remove_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["yay", "-Rns", item.identifier]

    def update_all_cmd(self) -> Optional[List[str]]:
        return ["yay", "-Syu"]


class FlatpakBackend(Backend):
    name = "flatpak"

    def is_available(self) -> bool:
        return shutil.which("flatpak") is not None

    def _installed_set(self) -> set:
        rc, out, _ = run_capture(["flatpak", "list", "--app", "--columns=application"])
        return {ln.strip() for ln in out.splitlines() if ln.strip()} if rc == 0 else set()

    def list_installed(self) -> List[SoftwareItem]:
        rc, out, err = run_capture(
            ["flatpak", "list", "--app", "--columns=application,name,version,branch,origin"]
        )
        if rc != 0:
            raise RuntimeError(err.strip() or "flatpak list failed")
        items: List[SoftwareItem] = []
        for line in out.splitlines():
            cols = [c.strip() for c in line.split("\t")]
            if not cols:
                continue
            app_id = cols[0]
            name = cols[1] if len(cols) > 1 else app_id
            ver = cols[2] if len(cols) > 2 else ""
            origin = cols[4] if len(cols) > 4 else ""
            items.append(SoftwareItem(
                name=name, source="flatpak", version=ver,
                summary=f"{app_id} ({origin})", identifier=app_id,
                installed=True, extra={"origin": origin},
            ))
        return items

    def search(self, query: str) -> List[SoftwareItem]:
        installed = self._installed_set()
        rc, out, _ = run_capture(
            ["flatpak", "search",
             "--columns=application,name,description,version,branch,remotes", query],
            timeout=180,
        )
        if rc != 0 and not out.strip():
            return []
        items: List[SoftwareItem] = []
        for line in out.splitlines():
            cols = [c.strip() for c in line.split("\t")]
            if not cols:
                continue
            app_id = cols[0]
            name = cols[1] if len(cols) > 1 and cols[1] else app_id
            desc = cols[2] if len(cols) > 2 else ""
            ver = cols[3] if len(cols) > 3 else ""
            remotes = cols[5] if len(cols) > 5 else ""
            items.append(SoftwareItem(
                name=name, source="flatpak", version=ver, summary=desc,
                identifier=app_id, installed=app_id in installed,
                extra={"remotes": remotes},
            ))
        return items

    def details(self, item: SoftwareItem) -> str:
        rc, out, err = run_capture(["flatpak", "info", item.identifier], timeout=60)
        return out.strip() if rc == 0 else (err.strip() or "No details available.")

    def install_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["flatpak", "install", "-y", item.identifier]

    def remove_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["flatpak", "uninstall", "-y", item.identifier]

    def update_all_cmd(self) -> Optional[List[str]]:
        return ["flatpak", "update", "-y"]


class SnapBackend(Backend):
    name = "snap"

    def is_available(self) -> bool:
        return shutil.which("snap") is not None

    def list_installed(self) -> List[SoftwareItem]:
        if not self.is_available():
            return []
        rc, out, err = run_capture(["snap", "list"], timeout=120)
        if rc != 0:
            raise RuntimeError(err.strip() or "snap list failed")
        items: List[SoftwareItem] = []
        for line in out.splitlines()[1:]:
            if not line.strip():
                continue
            parts = line.split()
            if len(parts) < 2:
                continue
            items.append(SoftwareItem(
                name=parts[0], source="snap", version=parts[1],
                installed=True, identifier=parts[0]
            ))
        return items

    def search(self, query: str) -> List[SoftwareItem]:
        if not self.is_available():
            return []
        installed_names = {i.identifier for i in self.list_installed()}
        rc, out, _ = run_capture(["snap", "find", "--color=never", query], timeout=120)
        if rc != 0 and not out.strip():
            return []
        items: List[SoftwareItem] = []
        for line in out.splitlines()[1:]:
            if not line.strip():
                continue
            parts = line.split(None, 4)
            if not parts:
                continue
            name = parts[0]
            ver = parts[1] if len(parts) > 1 else ""
            summary = parts[4] if len(parts) > 4 else ""
            items.append(SoftwareItem(
                name=name, source="snap", version=ver, summary=summary,
                identifier=name, installed=name in installed_names,
            ))
        return items

    def details(self, item: SoftwareItem) -> str:
        if not self.is_available():
            return "Snap is not installed."
        rc, out, err = run_capture(["snap", "info", item.identifier], timeout=60)
        return out.strip() if rc == 0 else (err.strip() or "No details available.")

    def install_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["sudo", "snap", "install", item.identifier]

    def remove_cmd(self, item: SoftwareItem) -> Optional[List[str]]:
        return ["sudo", "snap", "remove", item.identifier]

    def update_all_cmd(self) -> Optional[List[str]]:
        return ["sudo", "snap", "refresh"]


class AppImageBackend(Backend):
    name = "appimage"

    def __init__(self, appimage_dir: Path):
        self.appimage_dir = appimage_dir.expanduser()
        self.appimage_dir.mkdir(parents=True, exist_ok=True)

    def is_available(self) -> bool:
        return True

    def _scan(self) -> List[SoftwareItem]:
        return [
            SoftwareItem(
                name=p.stem, source="appimage", summary=str(p),
                identifier=str(p), installed=True,
            )
            for p in sorted(self.appimage_dir.glob("*.AppImage"))
        ]

    def list_installed(self) -> List[SoftwareItem]:
        return self._scan()

    def search(self, query: str) -> List[SoftwareItem]:
        q = query.lower().strip()
        return [i for i in self._scan()
                if not q or q in i.name.lower() or q in i.identifier.lower()]

    def details(self, item: SoftwareItem) -> str:
        p = Path(item.identifier)
        if not p.exists():
            return "File not found."
        try:
            st = p.stat()
            size_mb = st.st_size / (1024 * 1024)
            mode = "executable" if (st.st_mode & stat.S_IXUSR) else "not executable"
            return (f"AppImage: {p.name}\nPath: {p}\n"
                    f"Size: {size_mb:.1f} MiB\nStatus: {mode}")
        except Exception as e:
            return str(e)

    def launch(self, item: SoftwareItem) -> Optional[str]:
        p = Path(item.identifier)
        if not p.exists():
            return "AppImage file not found."
        try:
            st = p.stat()
            if not (st.st_mode & stat.S_IXUSR):
                p.chmod(st.st_mode | stat.S_IXUSR)
            subprocess.Popen([str(p)])
            return None
        except Exception as e:
            return str(e)

    def import_appimage(self, src_path: str) -> SoftwareItem:
        src = Path(src_path).expanduser()
        if not src.exists():
            raise FileNotFoundError(str(src))
        if src.suffix.lower() != ".appimage":
            raise RuntimeError("Selected file is not an .AppImage")
        dst = self.appimage_dir / src.name
        if dst.exists():
            raise RuntimeError("An AppImage with this name already exists.")
        shutil.copy2(src, dst)
        dst.chmod(dst.stat().st_mode | stat.S_IXUSR)
        return SoftwareItem(
            name=dst.stem, source="appimage", summary=str(dst),
            identifier=str(dst), installed=True
        )

    def delete_appimage(self, item: SoftwareItem):
        p = Path(item.identifier)
        if p.exists():
            p.unlink()


