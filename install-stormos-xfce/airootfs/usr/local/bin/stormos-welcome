# Logging setup
LOG_FILE = open('/tmp/stormos-hub.log', 'w')
def log(msg):
    LOG_FILE.write(msg + '\n')
    LOG_FILE.flush()

log("=== Starting StormOS Hub ===")

try:
    from PyQt6.QtCore import Qt, QTimer, QPropertyAnimation, QEasingCurve
    from PyQt6.QtGui import QIcon, QFont, QGuiApplication, QPalette, QColor
