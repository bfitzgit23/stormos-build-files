        parent_layout.addWidget(self.header)
        
    def create_content_area(self, parent_layout):
        """Create the main content area with video and playlist"""
        self.content_widget = QWidget()
        content_layout = QHBoxLayout(self.content_widget)
        content_layout.setContentsMargins(0, 0, 0, 0)
        content_layout.setSpacing(0)
        
        # Video widget (MUST be created before buffering indicator)
        self.video_widget = QVideoWidget()
        self.video_widget.setObjectName("VideoSurface")
        self.video_widget.installEventFilter(self)
        self.player.setVideoOutput(self.video_widget)
        content_layout.addWidget(self.video_widget, stretch=1)
        
        # Playlist drawer
        self.playlist_widget = QListWidget()
        self.playlist_widget.setObjectName("PlaylistDrawer")
        self.playlist_widget.setFixedWidth(0)  # Hidden by default
        self.playlist_widget.setSelectionMode(QAbstractItemView.SelectionMode.SingleSelection)
        self.playlist_widget.itemDoubleClicked.connect(self.on_playlist_double_click)
        self.playlist_widget.setContextMenuPolicy(Qt.ContextMenuPolicy.CustomContextMenu)
        self.playlist_widget.customContextMenuRequested.connect(self.show_playlist_menu)
        self.playlist_widget.setStyleSheet("""
            QListWidget {
                font-family: 'JetBrains Mono', monospace;
                font-size: 13px;
                padding: 8px;
            }
        """)
        
        content_layout.addWidget(self.playlist_widget)
        
        parent_layout.addWidget(self.content_widget, stretch=1)
        
        # Animation for playlist drawer
        self.playlist_animation = QPropertyAnimation(self.playlist_widget, b"maximumWidth")
        self.playlist_animation.setDuration(280)
        self.playlist_animation.setEasingCurve(QEasingCurve.Type.OutCubic)
        
