        hud_layout.addSpacing(20)
        hud_layout.addLayout(volume_layout)
        
        hud_container.addWidget(self.hud_widget)
        parent_layout.addLayout(hud_container)
        
    def init_shortcuts(self):
        """Initialize keyboard shortcuts with StormOS-friendly bindings"""
        shortcuts = [
            ('Space', self.toggle_playback),
            ('F', self.toggle_fullscreen),
            ('M', self.toggle_mute),
            ('H', self.toggle_hud),
            ('P', self.toggle_playlist),
            ('Up', lambda: self.set_volume(min(100, self.volume_slider.value() + 5))),
            ('Down', lambda: self.set_volume(max(0, self.volume_slider.value() - 5))),
            ('Left', lambda: self.seek_relative(-5000)),
            ('Right', lambda: self.seek_relative(5000)),
            ('Ctrl+Left', lambda: self.seek_relative(-60000)),
            ('Ctrl+Right', lambda: self.seek_relative(60000)),
            ('O', self.open_file),
            ('Q', self.close),
            ('N', self.play_next),
            ('B', self.play_previous),
            ('C', self.toggle_always_on_top),
            ('Esc', self.exit_fullscreen),
        ]
        
        for key, callback in shortcuts:
            shortcut = QShortcut(QKeySequence(key), self)
            shortcut.activated.connect(callback)
            shortcut.setContext(Qt.ShortcutContext.ApplicationShortcut)
    
    # ===== PLAYLIST MANAGEMENT =====
    def add_to_playlist(self, files, clear_first=False):
        """Add files to playlist with proper metadata display"""
        if clear_first:
            self.playlist_files.clear()
            self.playlist_widget.clear()
            self.current_index = -1
        
        start_index = len(self.playlist_files)
        for file_path in files:
            if os.path.isfile(file_path):
                self.playlist_files.append(file_path)
                filename = os.path.basename(file_path)
                item = QListWidgetItem(f"▶ {filename}")
                item.setData(Qt.ItemDataRole.UserRole, file_path)
                item.setToolTip(file_path)
                self.playlist_widget.addItem(item)
        
        # Select first newly added item
        if start_index < len(self.playlist_files):
            self.playlist_widget.setCurrentRow(start_index)
        
        self.playlistChanged.emit()
        return start_index
    
    def play_item(self, index):
        """Play item at specified index in playlist"""
        if 0 <= index < len(self.playlist_files):
            self.current_index = index
            file_path = self.playlist_files[index]
            
            # Update UI state
            self.player.setSource(QUrl.fromLocalFile(file_path))
            self.player.play()
            
            # Update title displays
            filename = os.path.basename(file_path)
            self.title_label.setText(filename.upper())
            self.update_window_title(filename)
            
            # Update playlist selection
            self.playlist_widget.blockSignals(True)
            self.playlist_widget.setCurrentRow(index)
            # Update play indicator in playlist
            for i in range(self.playlist_widget.count()):
                item = self.playlist_widget.item(i)
                text = item.text()
                if i == index:
                    item.setText(f"▶ {os.path.basename(self.playlist_files[i])}")
                elif text.startswith("▶ "):
                    item.setText(text[2:])
            self.playlist_widget.blockSignals(False)
            
            # Show notification
            self.show_notification(f"Now Playing: {filename}", duration=2500)
    
    def play_next(self):
        """Play next item in playlist (loop to start if at end)"""
        if not self.playlist_files:
            return
            
        next_index = (self.current_index + 1) % len(self.playlist_files)
        self.play_item(next_index)
    
    def play_previous(self):
        """Play previous item in playlist (loop to end if at start)"""
        if not self.playlist_files:
            return
            
        prev_index = (self.current_index - 1) % len(self.playlist_files)
        self.play_item(prev_index)
    
    def on_playlist_double_click(self, item):
        """Handle double-click on playlist item"""
        index = self.playlist_widget.row(item)
        self.play_item(index)
    
    def clear_playlist(self):
        """Clear the entire playlist"""
        self.playlist_files.clear()
        self.playlist_widget.clear()
        self.current_index = -1
        self.update_window_title("StormPlayer")
    
    def remove_selected_item(self):
        """Remove selected item from playlist"""
        current_row = self.playlist_widget.currentRow()
        if current_row >= 0:
            # Remove from data structures
            del self.playlist_files[current_row]
            self.playlist_widget.takeItem(current_row)
            
            # Adjust current index
            if current_row == self.current_index:
                self.current_index = -1
                self.player.stop()
                self.update_window_title("StormPlayer")
            elif current_row < self.current_index:
                self.current_index -= 1
            
            self.playlistChanged.emit()
    
    # ===== PLAYBACK CONTROL =====
    def toggle_playback(self):
        """Toggle between play and pause states"""
        if self.player.playbackState() == QMediaPlayer.PlaybackState.PlayingState:
            self.player.pause()
        else:
            if self.player.source().isEmpty() and self.playlist_files:
                self.play_item(0)
            else:
                self.player.play()
    
    def seek_relative(self, ms):
        """Seek forward/backward by specified milliseconds"""
        if self.player.duration() <= 0:
            return
            
        new_pos = self.player.position() + ms
        new_pos = max(0, min(self.player.duration(), new_pos))
        self.player.setPosition(new_pos)
    
    def on_slider_moved(self, position):
        """Update time display while slider is being dragged"""
        self.current_time.setText(self.format_time(position))
    
    def on_slider_released(self):
        """Seek to position when slider is released"""
        self.player.setPosition(self.seek_slider.value())
    
    def set_volume(self, value):
        """Set audio volume"""
        volume = value / 100.0
        self.audio_output.setVolume(volume)
        self.volume_slider.setValue(value)
        
        # Update volume icon
        if value == 0:
            self.volume_btn.setText("🔇")
        elif value < 33:
            self.volume_btn.setText("🔈")
        elif value < 66:
            self.volume_btn.setText("🔉")
        else:
            self.volume_btn.setText("🔊")
    
    def toggle_mute(self):
        """Toggle mute state"""
        if self.audio_output.volume() > 0:
            self.last_volume = self.audio_output.volume()
            self.audio_output.setVolume(0)
            self.volume_slider.setValue(0)
            self.volume_btn.setText("🔇")
        else:
            self.audio_output.setVolume(self.last_volume)
            self.volume_slider.setValue(int(self.last_volume * 100))
            self.set_volume(int(self.last_volume * 100))
    
    # ===== UI UPDATES =====
    def update_position(self, position):
        """Update position slider and time display"""
        if not self.seek_slider.isSliderDown():
            self.seek_slider.setValue(position)
            self.current_time.setText(self.format_time(position))
    
    def update_duration(self, duration):
        """Update duration display and slider range"""
        self.seek_slider.setRange(0, duration)
        self.duration_label.setText(f"/ {self.format_time(duration)}")
    
    def on_playback_state_changed(self, state):
        """Update UI based on playback state"""
        if state == QMediaPlayer.PlaybackState.PlayingState:
            self.play_btn.setText("⏸")
            self.play_btn.setStyleSheet(f"""
                QPushButton {{
                    color: {FG_GREEN};
                    font-size: 20px;
                    font-weight: bold;
                    background-color: rgba(80, 250, 123, 15);
                    border-radius: 26px;
                }}
                QPushButton:hover {{
                    background-color: rgba(80, 250, 123, 30);
                    color: {FG_DEFAULT};
                }}
            """)
            self.status_dot.setStyleSheet(f"color: {FG_GREEN};")
            self.status_dot.setText("●")
        elif state == QMediaPlayer.PlaybackState.PausedState:
            self.play_btn.setText("▶")
            self.play_btn.setStyleSheet(f"""
                QPushButton {{
                    color: {FG_YELLOW};
                    font-size: 20px;
                    font-weight: bold;
                    background-color: rgba(241, 250, 140, 15);
                    border-radius: 26px;
                }}
                QPushButton:hover {{
                    background-color: rgba(241, 250, 140, 30);
                    color: {FG_DEFAULT};
                }}
            """)
            self.status_dot.setStyleSheet(f"color: {FG_YELLOW};")
            self.status_dot.setText("●")
        else:  # StoppedState
            self.play_btn.setText("▶")
            self.play_btn.setStyleSheet(f"""
                QPushButton {{
                    color: {FG_PURPLE};
                    font-size: 20px;
                    font-weight: bold;
                    background-color: rgba(189, 147, 249, 15);
                    border-radius: 26px;
                }}
                QPushButton:hover {{
                    background-color: rgba(189, 147, 249, 30);
                    color: {FG_DEFAULT};
                }}
            """)
            self.status_dot.setStyleSheet(f"color: {FG_PURPLE};")
            self.status_dot.setText("○")
        
        self.playbackStateChanged.emit(state)
    
    def on_media_status_changed(self, status):
        """Handle end of media for playlist auto-advance"""
        from PyQt6.QtMultimedia import QMediaPlayer
        
        # Show/hide buffering indicator based on status
        if status == QMediaPlayer.MediaStatus.BufferingMedia:
            self.buffering_progress.show()
        elif status == QMediaPlayer.MediaStatus.BufferedMedia:
            self.buffering_progress.hide()
        elif status == QMediaPlayer.MediaStatus.EndOfMedia:
            if self.playlist_files and len(self.playlist_files) > 1:
                self.play_next()
    
    def format_time(self, ms):
        """Format milliseconds into human-readable time string"""
        if ms < 0:
            return "00:00"
        
        total_seconds = ms // 1000
        hours = total_seconds // 3600
        minutes = (total_seconds % 3600) // 60
        seconds = total_seconds % 60
        
        if hours > 0:
            return f"{hours}:{minutes:02d}:{seconds:02d}"
        else:
            return f"{minutes:02d}:{seconds:02d}"
    
    def update_window_title(self, title):
        """Update window title with StormOS branding"""
        self.setWindowTitle(f"{title} - StormPlayer ⚡ StormOS")
    
    # ===== WINDOW MANAGEMENT =====
    def toggle_playlist(self):
        """Toggle playlist drawer visibility with animation"""
        self.playlist_visible = not self.playlist_visible
        
        self.playlist_animation.stop()
        self.playlist_animation.setStartValue(self.playlist_widget.width())
        self.playlist_animation.setEndValue(320 if self.playlist_visible else 0)
        self.playlist_animation.start()
        
        # Update button text
        self.playlist_btn.setText("≡ HIDE" if self.playlist_visible else "≡ PLAYLIST")
    
    def toggle_hud(self):
        """Toggle HUD visibility"""
        self.hud_visible = not self.hud_visible
        self.hud_widget.setVisible(self.hud_visible)
        
        # Update button appearance
        if self.hud_visible:
            self.hud_btn.setText("👁 HUD")
            self.hud_btn.setStyleSheet(f"color: {FG_PURPLE};")
        else:
            self.hud_btn.setText("❌ HUD")
            self.hud_btn.setStyleSheet(f"color: {FG_COMMENT};")
    
    def toggle_fullscreen(self):
        """Toggle fullscreen mode"""
        if self.is_fullscreen:
            self.showNormal()
            self.is_fullscreen = False
            self.header.show()
            self.hud_widget.setVisible(self.hud_visible)
            self.setCursor(Qt.CursorShape.ArrowCursor)
        else:
            self.showFullScreen()
            self.is_fullscreen = True
            self.header.hide()
            self.hud_widget.setVisible(self.hud_visible)
            # Start cursor auto-hide timer
            self.cursor_timer.start(3000)
    
    def exit_fullscreen(self):
        """Exit fullscreen mode when Esc is pressed"""
        if self.is_fullscreen:
            self.toggle_fullscreen()
    
    def hide_cursor_in_fullscreen(self):
        """Auto-hide cursor in fullscreen mode after inactivity"""
        if self.is_fullscreen:
            self.setCursor(Qt.CursorShape.BlankCursor)
    
    def toggle_maximize_restore(self):
        """Toggle between maximized and normal window states"""
        if self.isMaximized():
            self.showNormal()
            self.max_btn.setText("❐")
            self.is_maximized = False
        else:
            self.showMaximized()
            self.max_btn.setText("❐")
            self.is_maximized = True
    
    def toggle_always_on_top(self):
        """Toggle always-on-top window behavior"""
        flags = self.windowFlags()
        if flags & Qt.WindowType.WindowStaysOnTopHint:
            self.setWindowFlags(flags & ~Qt.WindowType.WindowStaysOnTopHint)
        else:
            self.setWindowFlags(flags | Qt.WindowType.WindowStaysOnTopHint)
        self.show()
    
    # ===== FILE OPERATIONS =====
    def open_file(self):
        """Open a media file dialog"""
        home_dir = str(Path.home())
        path, _ = QFileDialog.getOpenFileName(
            self, 
            "Open Media File", 
            home_dir,
            "Media Files (*.mp4 *.mkv *.avi *.mov *.webm *.mp3 *.wav *.flac *.ogg *.m4a);;Video Files (*.mp4 *.mkv *.avi *.mov *.webm);;Audio Files (*.mp3 *.wav *.flac *.ogg *.m4a);;All Files (*)"
        )
        if path and os.path.isfile(path):
            self.add_to_playlist([path], clear_first=False)
            self.play_item(len(self.playlist_files) - 1)
    
    def open_files(self):
        """Open multiple media files"""
        home_dir = str(Path.home())
        paths, _ = QFileDialog.getOpenFileNames(
            self,
            "Open Multiple Files",
            home_dir,
            "Media Files (*.mp4 *.mkv *.avi *.mov *.webm *.mp3 *.wav *.flac *.ogg *.m4a);;All Files (*)"
        )
        if paths:
            self.add_to_playlist(paths, clear_first=False)
            self.play_item(len(self.playlist_files) - len(paths))
    
    def on_media_error(self, error, error_string):
        """Handle media playback errors"""
        QMessageBox.critical(
            self,
            "Playback Error",
            f"Error: {error_string}\n\nError code: {error}"
        )
        self.status_dot.setStyleSheet(f"color: {FG_RED};")
        self.status_dot.setText("✖")
    
    # ===== DRAG AND DROP =====
    def dragEnterEvent(self, event):
        if event.mimeData().hasUrls():
            event.acceptProposedAction()
            self.video_widget.setStyleSheet(f"""
                #VideoSurface {{
                    background-color: rgba(189, 147, 249, 30);
                    border: 2px dashed {FG_PURPLE};
                    border-radius: 12px;
                }}
            """)
        else:
            event.ignore()
    
    def dragLeaveEvent(self, event):
        self.video_widget.setStyleSheet(f"""
            #VideoSurface {{
                background-color: #000000;
                border-radius: 12px;
            }}
        """)
    
    def dropEvent(self, event):
        self.video_widget.setStyleSheet(f"""
            #VideoSurface {{
                background-color: #000000;
                border-radius: 12px;
            }}
        """)
        
        files = [u.toLocalFile() for u in event.mimeData().urls() if u.isLocalFile()]
        media_files = [f for f in files if os.path.isfile(f) and self.is_media_file(f)]
        
        if media_files:
            start_index = self.add_to_playlist(media_files, clear_first=False)
            self.play_item(start_index)
        
        event.acceptProposedAction()
    
    def is_media_file(self, filepath):
        """Check if file is a supported media type"""
        ext = os.path.splitext(filepath)[1].lower()
        media_exts = {
            '.mp4', '.mkv', '.avi', '.mov', '.webm', '.flv', '.wmv',  # Video
            '.mp3', '.wav', '.flac', '.ogg', '.m4a', '.aac', '.wma'   # Audio
        }
        return ext in media_exts
    
    # ===== CONTEXT MENUS =====
    def show_main_context_menu(self, pos):
        """Show main window context menu"""
        menu = QMenu(self)
        menu.setStyleSheet(STYLING)
        
        # File operations
        menu.addAction("➕ Open File...", self.open_file)
        menu.addAction("➕ Open Multiple Files...", self.open_files)
        menu.addAction("≡ Toggle Playlist (P)", self.toggle_playlist)
        menu.addAction("👁 Toggle HUD (H)", self.toggle_hud)
        menu.addSeparator()
        
        # Playback controls
        menu.addAction("⏯ Play/Pause (Space)", self.toggle_playback)
        menu.addAction("⏮ Previous Track (B)", self.play_previous)
        menu.addAction("⏭ Next Track (N)", self.play_next)
        menu.addSeparator()
        
        # View options
        menu.addAction("⛶ Toggle Fullscreen (F)", self.toggle_fullscreen)
        
        always_on_top = QAction("📌 Always on Top (C)", self)
        always_on_top.setCheckable(True)
        always_on_top.setChecked(bool(self.windowFlags() & Qt.WindowType.WindowStaysOnTopHint))
        always_on_top.triggered.connect(self.toggle_always_on_top)
        menu.addAction(always_on_top)
        
        ghost_mode = QAction("👻 Ghost Mode (85% Opacity)", self)
        ghost_mode.setCheckable(True)
        ghost_mode.setChecked(self.windowOpacity() < 1.0)
        ghost_mode.triggered.connect(lambda checked: self.setWindowOpacity(0.85 if checked else 1.0))
        menu.addAction(ghost_mode)
        
        menu.addSeparator()
        
        # System integration
        menu.addAction("ℹ️ About StormPlayer", self.show_about_dialog)
        menu.addAction("🚪 Exit", self.close)
        
        menu.exec(self.mapToGlobal(pos))
    
    def show_playlist_menu(self, pos):
        """Show playlist context menu"""
        item = self.playlist_widget.itemAt(pos)
        menu = QMenu(self)
        menu.setStyleSheet(STYLING)
        
        if item:
            menu.addAction("▶ Play Now", lambda: self.on_playlist_double_click(item))
            menu.addAction("🗑 Remove from Playlist", self.remove_selected_item)
            menu.addSeparator()
        
        menu.addAction("➕ Add Files...", self.open_files)
        menu.addAction("🗑 Clear Playlist", self.clear_playlist)
        
        menu.exec(self.playlist_widget.mapToGlobal(pos))
    
    def show_about_dialog(self):
        """Show StormPlayer about dialog"""
        dialog = QDialog(self)
        dialog.setWindowTitle("About StormPlayer")
        dialog.setFixedSize(400, 300)
        dialog.setStyleSheet(f"""
            QDialog {{
                background-color: {BG_DARKER};
                border-radius: 12px;
            }}
            QLabel {{
                color: {FG_DEFAULT};
                font-family: 'JetBrains Mono', monospace;
                font-size: 14px;
            }}
            QLabel#title {{
                color: {STORMOS_PURPLE};
                font-size: 20px;
                font-weight: bold;
            }}
            QLabel#version {{
                color: {FG_COMMENT};
                font-size: 14px;
            }}
            QLabel#desc {{
                color: {FG_YELLOW};
                font-size: 15px;
            }}
        """)
        
        layout = QVBoxLayout(dialog)
        layout.setContentsMargins(24, 24, 24, 24)
        layout.setSpacing(16)
        
        # Logo/title
        title_label = QLabel("⚡ STORMPLAYER")
